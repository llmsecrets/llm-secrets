#!/bin/bash
# scrt4 - secure secret injector CLI (WebAuthn PRF edition)
# Wrapper for scrt4-daemon via Unix socket
#
# Authentication: WebAuthn PRF via QR code (phone scans, authenticates on auth.llmsecrets.com)
# Encryption: AES-256-GCM with PRF-derived key
# View: GUI challenge (Zenity) to prevent AI agents from seeing secrets

set -euo pipefail

VERSION="0.1.0"
SOCKET="${XDG_RUNTIME_DIR:-/tmp}/scrt4.sock"
CONFIG_DIR="$HOME/.scrt4"
TAGS_FILE="$CONFIG_DIR/tags.json"
WALLET_CONFIG="$CONFIG_DIR/wallet.json"
RELAY_BASE="https://auth.llmsecrets.com"
RELAY_POLL="https://llmsecrets-auth.vercel.app"  # CLI polling (bypasses Meraki filter)

# Force CLI mode (skip Zenity) — set by --cli flag or "agent" submode
FORCE_CLI=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ── Communication ────────────────────────────────────────────────────
send_request() {
    local json="$1"
    local timeout="${2:-10}"
    if command -v socat &>/dev/null; then
        echo "$json" | socat - UNIX-CONNECT:"$SOCKET" 2>/dev/null
    else
        # Use Python for reliable single-write Unix socket communication
        # (nc splits large payloads across multiple writes, breaking the daemon's parser)
        python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout($timeout)
s.connect('$SOCKET')
data = b' '.join(sys.stdin.buffer.read().split()) + b'\n'
s.sendall(data)
s.shutdown(socket.SHUT_WR)
chunks = []
while True:
    try:
        d = s.recv(65536)
        if not d: break
        chunks.append(d)
    except: break
s.close()
sys.stdout.buffer.write(b''.join(chunks))
" <<< "$json" 2>/dev/null
    fi
}

# ── QR Code Display ──────────────────────────────────────────────────

# Render QR code in terminal using half-block characters
show_qr_terminal() {
    local url="$1"
    echo ""
    echo -e "  ${YELLOW}If the QR code is cut off, press Ctrl+0 to expand the terminal${NC}"
    echo ""
    if command -v qrencode &>/dev/null; then
        qrencode -t ANSIUTF8 -m 1 -l L "$url"
    else
        echo -e "  ${YELLOW}Install qrencode for QR display (apt install qrencode / brew install qrencode)${NC}"
    fi
    echo ""
    echo -e "  ${CYAN}If the QR code isn't working, copy this URL to your phone:${NC}"
    echo -e "  ${url}"
    echo ""
}


# ── Relay Polling ────────────────────────────────────────────────────

# Poll relay endpoint until payload appears (blocking, for CLI mode)
poll_relay() {
    local session_id="$1"
    local url="${RELAY_POLL}/api/relay/${session_id}"

    while true; do
        local body
        body=$(curl -sf "$url" 2>/dev/null) || true
        if [ -n "$body" ]; then
            local payload
            payload=$(echo "$body" | jq -r '.payload // empty' 2>/dev/null)
            if [ -n "$payload" ]; then
                echo "$payload"
                return 0
            fi
        fi
        sleep 1.5
    done
}

# Poll relay with Zenity progress dialog (for GUI mode)
# Opens QR in system image viewer + shows URL in Zenity
# Returns encrypted payload via stdout
poll_relay_gui() {
    local session_id="$1"
    local url="$2"
    local result_file="/tmp/scrt4-result-$$.txt"

    # Start relay polling in background
    (
        while true; do
            local body
            body=$(curl -sf "${RELAY_POLL}/api/relay/${session_id}" 2>/dev/null) || true
            if [ -n "$body" ]; then
                local payload
                payload=$(echo "$body" | jq -r '.payload // empty' 2>/dev/null)
                if [ -n "$payload" ]; then
                    echo "$payload" > "$result_file"
                    exit 0
                fi
            fi
            sleep 1.5
        done
    ) &
    local poll_pid=$!

    # Show Zenity progress (pulsating bar while waiting)
    (
        while kill -0 $poll_pid 2>/dev/null; do
            if [ -f "$result_file" ]; then
                echo "100"
                break
            fi
            echo "#"
            sleep 1
        done
    ) | zenity --progress --pulsate --auto-close \
        --title="LLM Secrets — Waiting for Phone" \
        --text="Scan the QR code in the terminal with your phone camera.\n\nOr open this URL on your phone:\n<span font_family='monospace' font='10'>${url}</span>\n\nWaiting for authentication..." \
        --cancel-label="  Cancel  " \
        --width=520 2>/dev/null
    local zenity_rc=$?

    # If user canceled
    if [ $zenity_rc -ne 0 ] && [ ! -f "$result_file" ]; then
        kill $poll_pid 2>/dev/null
        wait $poll_pid 2>/dev/null
        rm -f "$result_file"
        return 1
    fi

    # Wait for poll to finish
    wait $poll_pid 2>/dev/null

    local result=""
    [ -f "$result_file" ] && result=$(cat "$result_file")

    rm -f "$result_file"

    if [ -z "$result" ]; then
        return 1
    fi

    echo "$result"
}

# ── AuthCode ─────────────────────────────────────────────────────────

# Generate a 4-digit AuthCode via the relay's /api/relay/shorten endpoint.
# Users can type this code at auth.llmsecrets.com instead of scanning a QR code.
# Returns the full URL (unchanged) — the code is stored in AUTHCODE_DISPLAY.
AUTHCODE_DISPLAY=""

shorten_qr_url() {
    local full_url="$1"
    local session_id="$2"
    AUTHCODE_DISPLAY=""

    # Request a 4-digit code from the relay
    local shorten_resp
    shorten_resp=$(curl -sf -X POST "${RELAY_POLL}/api/relay/shorten" \
        -H "Content-Type: application/json" \
        -d "{\"session_id\":\"${session_id}\"}" 2>/dev/null) || true

    if [ -n "$shorten_resp" ]; then
        local code
        code=$(echo "$shorten_resp" | jq -r '.code // empty' 2>/dev/null)
        if [ -n "$code" ]; then
            AUTHCODE_DISPLAY="$code"
        fi
    fi

    echo "$full_url"
}

# ── WebAuthn Setup Flow ──────────────────────────────────────────────

run_setup_flow() {
    # Phase 1: Get relay URL from daemon
    local response
    response=$(send_request '{"method":"setup_webauthn"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" != "true" ]; then
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Setup failed: ${error}${NC}" >&2
        return 1
    fi

    local full_url=$(echo "$response" | jq -r '.data.url')
    local session_id=$(echo "$response" | jq -r '.data.session_id')
    local wrapping_key=$(echo "$response" | jq -r '.data.wrapping_key')
    local prf_salt_b64=$(echo "$response" | jq -r '.data.prf_salt_b64')

    # Shorten URL for smaller QR code + generate AuthCode
    local url
    url=$(shorten_qr_url "$full_url" "$session_id")

    # Always print URL for headless/SSH environments
    echo -e "  ${CYAN}Auth URL:${NC} ${url}" >&2

    # Display AuthCode if available
    if [ -n "$AUTHCODE_DISPLAY" ]; then
        echo "" >&2
        echo -e "  ${CYAN}AuthCode:${NC}  ${GREEN}${AUTHCODE_DISPLAY}${NC}" >&2
        echo -e "  Enter at ${CYAN}auth.llmsecrets.com${NC}" >&2
        echo "" >&2
    fi

    # Send push notification to registered devices (non-blocking, JSON-safe)
    local push_json
    push_json=$(jq -nc --arg sid "$session_id" --arg url "$full_url" '{session_id: $sid, auth_url: $url}')
    curl -sf -X POST "${RELAY_POLL}/api/relay/push" \
        -H "Content-Type: application/json" \
        -d "$push_json" \
        -o /tmp/scrt4-push-result.json 2>/tmp/scrt4-push-err.log &

    # Phase 2: Show QR code and wait for phone
    # Always render QR + instructions in terminal first, regardless of GUI availability
    show_qr_terminal "$url"
    if [ -n "$AUTHCODE_DISPLAY" ]; then
        echo -e "  Scan the QR code or enter AuthCode ${GREEN}${AUTHCODE_DISPLAY}${NC} at auth.llmsecrets.com" >&2
    else
        echo -e "  Scan the QR code with your phone camera." >&2
    fi
    echo -e "  Then tap 'Register Passkey' on the page." >&2
    echo "" >&2

    local payload=""

    if [ "$FORCE_CLI" = false ] && command -v zenity &>/dev/null; then
        payload=$(poll_relay_gui "$session_id" "$url") || {
            # Zenity failed or was cancelled — fallback to CLI polling
            echo -e "${YELLOW}GUI unavailable, switching to terminal mode...${NC}" >&2
            echo -ne "  ${CYAN}Waiting for phone...${NC}"
            payload=$(poll_relay "$session_id")
            echo -e " ${GREEN}received!${NC}"
        }
    else
        echo -ne "  ${CYAN}Waiting for phone...${NC}"
        payload=$(poll_relay "$session_id")
        echo -e " ${GREEN}received!${NC}"
    fi

    # Phase 3: Send to daemon for completion
    echo -e "${CYAN}Completing registration...${NC}"
    local complete_json
    complete_json=$(jq -cn \
        --arg payload "$payload" \
        --arg key "$wrapping_key" \
        --arg salt "$prf_salt_b64" \
        '{method:"setup_webauthn_complete",params:{encrypted_payload:$payload,wrapping_key:$key,prf_salt_b64:$salt}}')

    response=$(send_request "$complete_json")
    success=$(echo "$response" | jq -r '.success // false')

    if [ "$success" = "true" ]; then
        echo -e "${GREEN}Credential registered successfully!${NC}"
        echo -e "${GREEN}Empty secret store created.${NC}"
        echo -e "${CYAN}Add secrets with: scrt4 add KEY=value${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Registration failed: ${error}${NC}" >&2
        return 1
    fi
}

# ── Localhost WebAuthn Flows ──────────────────────────────────────────

# Open URL in the system browser
open_browser() {
    local url="$1"
    if command -v wslpath &>/dev/null && command -v cmd.exe &>/dev/null; then
        # WSL2: open in Windows browser
        cmd.exe /c start "" "$url" &>/dev/null
    elif command -v xdg-open &>/dev/null; then
        xdg-open "$url" &>/dev/null &
    elif command -v open &>/dev/null; then
        open "$url" &>/dev/null &
    else
        echo -e "  ${YELLOW}Could not open browser. Open this URL manually:${NC}" >&2
        echo -e "  ${url}" >&2
    fi
}

run_unlock_local_flow() {
    local ttl="${1:-60000}"

    # Phase 1: Start local server
    local response
    response=$(send_request "{\"method\":\"unlock_local\",\"params\":{\"ttl\":$ttl}}")

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" != "true" ]; then
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        # Check if credential needs re-registration
        if echo "$error" | grep -q "rpId"; then
            echo -e "${YELLOW}${error}${NC}" >&2
            echo -e "${YELLOW}Falling back to remote QR flow...${NC}" >&2
            run_unlock_flow "$ttl"
            return $?
        fi
        echo -e "${RED}Unlock failed: ${error}${NC}" >&2
        return 1
    fi

    local url=$(echo "$response" | jq -r '.data.url')

    # Open browser
    echo -e "${CYAN}Opening browser for authentication...${NC}" >&2
    open_browser "$url"
    echo -e "  ${CYAN}URL:${NC} ${url}" >&2
    echo -e "  Authenticate in the browser window, then tap your phone." >&2
    echo "" >&2

    # Phase 2: Wait for completion (long timeout — daemon blocks until browser posts back)
    echo -ne "  ${CYAN}Waiting for authentication...${NC}" >&2
    response=$(send_request "{\"method\":\"unlock_local_complete\",\"params\":{\"ttl\":$ttl}}" 180)
    echo "" >&2

    success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local count=$(echo "$response" | jq -r '.data.count // 0')
        echo -e "${GREEN}Unlocked ${count} secret(s).${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Unlock failed: ${error}${NC}" >&2
        return 1
    fi
}

run_setup_local_flow() {
    # Phase 1: Start local server for registration (requires active session)
    local response
    response=$(send_request '{"method":"setup_local"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" != "true" ]; then
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Setup failed: ${error}${NC}" >&2
        return 1
    fi

    local url=$(echo "$response" | jq -r '.data.url')

    # Open browser
    echo -e "${CYAN}Adding localhost passkey (wraps existing master key)...${NC}" >&2
    open_browser "$url"
    echo -e "  ${CYAN}URL:${NC} ${url}" >&2
    echo -e "  Register a passkey in the browser window." >&2
    echo "" >&2

    # Phase 2: Wait for completion
    echo -ne "  ${CYAN}Waiting for registration...${NC}" >&2
    response=$(send_request '{"method":"setup_local_complete"}' 180)
    echo "" >&2

    success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        echo -e "${GREEN}Localhost credential added!${NC}"
        echo -e "${GREEN}You can now unlock with 'scrt4 unlock' (no internet needed).${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Registration failed: ${error}${NC}" >&2
        return 1
    fi
}

# ── Remote WebAuthn Unlock Flow (QR/relay fallback) ──────────────────

run_unlock_flow() {
    local ttl="${1:-60000}"

    # Phase 1: Get relay URL from daemon
    local response
    response=$(send_request "{\"method\":\"unlock_webauthn\",\"params\":{\"ttl\":$ttl}}")

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" != "true" ]; then
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Unlock failed: ${error}${NC}" >&2
        return 1
    fi

    local full_url=$(echo "$response" | jq -r '.data.url // empty')
    local session_id=$(echo "$response" | jq -r '.data.session_id // empty')
    local wrapping_key=$(echo "$response" | jq -r '.data.wrapping_key // empty')

    # If no URL, it's a direct response (already unlocked?)
    if [ -z "$full_url" ]; then
        local count=$(echo "$response" | jq -r '.data.count // empty')
        if [ -n "$count" ]; then
            echo -e "${GREEN}Unlocked (${count} secrets)${NC}"
        else
            echo -e "${GREEN}OK${NC}"
        fi
        return 0
    fi

    # Shorten URL for smaller QR code + generate AuthCode
    local url
    url=$(shorten_qr_url "$full_url" "$session_id")

    # Always print URL for headless/SSH environments
    echo -e "  ${CYAN}Auth URL:${NC} ${url}" >&2

    # Display AuthCode if available
    if [ -n "$AUTHCODE_DISPLAY" ]; then
        echo "" >&2
        echo -e "  ${CYAN}AuthCode:${NC}  ${GREEN}${AUTHCODE_DISPLAY}${NC}" >&2
        echo -e "  Enter at ${CYAN}auth.llmsecrets.com${NC}" >&2
        echo "" >&2
    fi

    # Send push notification to registered devices (non-blocking, JSON-safe)
    local push_json
    push_json=$(jq -nc --arg sid "$session_id" --arg url "$full_url" '{session_id: $sid, auth_url: $url}')
    curl -sf -X POST "${RELAY_POLL}/api/relay/push" \
        -H "Content-Type: application/json" \
        -d "$push_json" \
        -o /tmp/scrt4-push-result.json 2>/tmp/scrt4-push-err.log &

    # Phase 2: Show QR code and wait for phone
    # Always render QR + instructions in terminal first, regardless of GUI availability
    show_qr_terminal "$url"
    if [ -n "$AUTHCODE_DISPLAY" ]; then
        echo -e "  Scan the QR code or enter AuthCode ${GREEN}${AUTHCODE_DISPLAY}${NC} at auth.llmsecrets.com" >&2
    else
        echo -e "  Scan the QR code with your phone camera." >&2
    fi
    echo -e "  Then tap 'Unlock with Passkey' on the page." >&2
    echo "" >&2

    local payload=""

    if [ "$FORCE_CLI" = false ] && command -v zenity &>/dev/null; then
        payload=$(poll_relay_gui "$session_id" "$url") || {
            # Zenity failed or was cancelled — fallback to CLI polling
            echo -e "${YELLOW}GUI unavailable, switching to terminal mode...${NC}" >&2
            echo -ne "  ${CYAN}Waiting for phone...${NC}"
            payload=$(poll_relay "$session_id")
            echo -e " ${GREEN}received!${NC}"
        }
    else
        echo -ne "  ${CYAN}Waiting for phone...${NC}"
        payload=$(poll_relay "$session_id")
        echo -e " ${GREEN}received!${NC}"
    fi

    # Phase 3: Send to daemon for completion
    echo -e "${CYAN}Decrypting vault...${NC}"
    local complete_json
    complete_json=$(jq -cn \
        --arg payload "$payload" \
        --arg key "$wrapping_key" \
        --argjson ttl "$ttl" \
        '{method:"unlock_webauthn_complete",params:{encrypted_payload:$payload,wrapping_key:$key,ttl:$ttl}}')

    response=$(send_request "$complete_json")
    success=$(echo "$response" | jq -r '.success // false')

    if [ "$success" = "true" ]; then
        local count=$(echo "$response" | jq -r '.data.count // 0')
        echo -e "${GREEN}Unlocked ${count} secret(s).${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Unlock failed: ${error}${NC}" >&2
        return 1
    fi
}

# ── Session Helper ───────────────────────────────────────────────────

# Check if session is active; if not, run the full unlock flow
ensure_unlocked() {
    local status_response
    status_response=$(send_request '{"method":"status"}' 2>/dev/null)
    local active=$(echo "$status_response" | jq -r '.data.active // false' 2>/dev/null)
    if [ "$active" = "true" ]; then
        return 0
    fi
    echo -e "${YELLOW}Session not active. Unlocking vault...${NC}"
    cmd_unlock
}

# True if a usable GUI is available: zenity binary is installed AND an X11
# or Wayland display is actually reachable. The binary check alone is not
# enough — the hardened Docker image has zenity installed but no DISPLAY,
# so every zenity call fails with "Gtk-WARNING: Failed to open display"
# and returns exit 1. Without this guard, code that gates UI on zenity
# presence falls into a dead branch (e.g. `scrt4 receive` would receive
# the payload, invoke zenity for the import confirmation, zenity would
# silently fail, and the script would print "Cancelled. No secrets
# imported." — losing the transfer). Callers should use this helper
# instead of `command -v zenity` when what they really want to know is
# "can I put a dialog on screen right now?"
_has_gui() {
    command -v zenity >/dev/null 2>&1 || return 1
    [ -n "${DISPLAY:-}" ] || [ -n "${WAYLAND_DISPLAY:-}" ]
}

# Run a command in the background if GUI mode (zenity usable, not --cli).
# Keeps terminal unblocked while Zenity dialogs are open. When no display
# is available, stay in the foreground so the caller can fall back to
# text-mode prompts — backgrounding here would hide the prompt.
_bg_if_gui() {
    local has_cli=false
    for arg in "$@"; do
        [ "$arg" = "--cli" ] && has_cli=true
    done
    if [ "$FORCE_CLI" = true ] || [ "$has_cli" = true ] || ! _has_gui; then
        "$@"
    else
        "$@" &
        disown
    fi
}

# Run WebAuthn verification if WA is enabled, otherwise no-op.
# Returns 0 on success (or if WA is off). Returns 1 on failure/cancel.
_wa_gate() {
    echo -e "${CYAN}WebAuthn verification required...${NC}"

    # Try localhost browser flow first
    local _start
    _start=$(send_request '{"method":"unlock_local","params":{"ttl":7200}}')
    if [ "$(echo "$_start" | jq -r '.success // false')" = "true" ]; then
        local _url=$(echo "$_start" | jq -r '.data.url')
        echo -e "${CYAN}Opening browser for authentication...${NC}" >&2
        open_browser "$_url"
        echo -e "  ${CYAN}URL:${NC} ${_url}" >&2
        echo -e "  Authenticate in the browser window." >&2
        echo "" >&2
        echo -ne "  ${CYAN}Waiting for authentication...${NC}" >&2
        local _done
        _done=$(send_request '{"method":"unlock_local_complete","params":{"ttl":7200}}' 180)
        echo "" >&2
        if [ "$(echo "$_done" | jq -r '.success // false')" = "true" ]; then
            echo -e "${GREEN}WebAuthn verified.${NC}"
            return 0
        fi
    fi

    # Fall back to remote QR/phone flow
    echo -e "${YELLOW}Trying remote authentication...${NC}"
    run_unlock_flow "7200" || {
        echo -e "${RED}WebAuthn verification failed.${NC}" >&2
        return 1
    }
    return 0
}

# Get reveal_all challenge+code. If WA is on, auto-completes via _wa_gate.
# If WA is off, shows 6-digit code for user to type.
# On success, sets: _REVEAL_CHALLENGE and _REVEAL_CODE (caller uses these).
_REVEAL_CHALLENGE=""
_REVEAL_CODE=""

_reveal_gate() {
    _REVEAL_CHALLENGE=""
    _REVEAL_CODE=""

    # WebAuthn gate — always required, then auto-complete the 6-digit code
    _wa_gate || return 1

    local _ch_resp
    _ch_resp=$(send_request '{"method":"reveal_all"}')
    if [ "$(echo "$_ch_resp" | jq -r '.success // false')" != "true" ]; then
        echo -e "${RED}$(echo "$_ch_resp" | jq -r '.error // "Unknown error"')${NC}" >&2
        return 1
    fi
    _REVEAL_CHALLENGE=$(echo "$_ch_resp" | jq -r '.data.challenge')
    _REVEAL_CODE=$(echo "$_ch_resp" | jq -r '.data.code')
    return 0
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_setup() {
    local use_local=false

    # Parse args
    for arg in "$@"; do
        case "$arg" in
            agent|--cli)  FORCE_CLI=true ;;
            --local)      use_local=true ;;
        esac
    done

    if [ "$use_local" = true ]; then
        # Add localhost credential (requires active session from phone unlock)
        run_setup_local_flow
        return $?
    fi

    # Default: remote (phone) setup — generates new keys

    # Warn if existing secrets might be lost
    local _existing_secrets=0
    local _list_resp
    _list_resp=$(send_request '{"method":"list"}' 2>/dev/null) && {
        _existing_secrets=$(echo "$_list_resp" | jq -r '.data.names | length // 0' 2>/dev/null)
    }

    if [ "$_existing_secrets" -gt 0 ] 2>/dev/null; then
        echo ""
        echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  WARNING: You have existing secrets in your vault!      ║${NC}"
        echo -e "${RED}╠══════════════════════════════════════════════════════════╣${NC}"
        echo -e "${RED}║  Setting up WebAuthn generates new encryption keys.     ║${NC}"
        echo -e "${RED}║  ALL existing secrets will be permanently deleted.      ║${NC}"
        echo -e "${RED}╠══════════════════════════════════════════════════════════╣${NC}"
        echo -e "${RED}║  Before proceeding, you should:                         ║${NC}"
        echo -e "${RED}║    1. Run 'scrt4 backup-key --save ~/Desktop'           ║${NC}"
        echo -e "${RED}║       (saves encrypted master key backup)               ║${NC}"
        echo -e "${RED}║    2. Run 'scrt4 view' and copy your secret values      ║${NC}"
        echo -e "${RED}║    3. After setup, re-add with 'scrt4 add KEY=value'    ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -n "Type YES to proceed, or anything else to abort: "
        read -r _confirm
        if [ "$_confirm" != "YES" ]; then
            echo -e "${YELLOW}Aborted. Your secrets are safe.${NC}"
            return 0
        fi
        echo ""
    fi

    run_setup_flow
}

cmd_unlock() {
    local ttl="60000"
    local force_mode=""

    # Parse args: [--cli] [--remote] [--local] [ttl]
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cli|agent)
                FORCE_CLI=true
                shift
                ;;
            --remote)
                force_mode="remote"
                shift
                ;;
            --local)
                force_mode="local"
                shift
                ;;
            *)
                ttl="$1"
                shift
                ;;
        esac
    done

    case "$force_mode" in
        remote) run_unlock_flow "$ttl" ;;
        local)  run_unlock_local_flow "$ttl" ;;
        *)
            # Default: try localhost if configured, otherwise remote
            local _check
            _check=$(send_request "{\"method\":\"unlock_local\",\"params\":{\"ttl\":$ttl}}")
            local _ok=$(echo "$_check" | jq -r '.success // false')
            if [ "$_ok" = "true" ]; then
                # Local server started — proceed with phase 2
                local _url=$(echo "$_check" | jq -r '.data.url')
                echo -e "${CYAN}Opening browser for authentication...${NC}" >&2
                open_browser "$_url"
                echo -e "  ${CYAN}URL:${NC} ${_url}" >&2
                echo -e "  Authenticate in the browser window." >&2
                echo "" >&2
                echo -ne "  ${CYAN}Waiting for authentication...${NC}" >&2
                local _resp
                _resp=$(send_request "{\"method\":\"unlock_local_complete\",\"params\":{\"ttl\":$ttl}}" 180)
                echo "" >&2
                local _success=$(echo "$_resp" | jq -r '.success // false')
                if [ "$_success" = "true" ]; then
                    local _count=$(echo "$_resp" | jq -r '.data.count // 0')
                    echo -e "${GREEN}Unlocked ${_count} secret(s).${NC}"
                else
                    local _error=$(echo "$_resp" | jq -r '.error // "Unknown error"')
                    echo -e "${RED}Unlock failed: ${_error}${NC}" >&2
                    return 1
                fi
            else
                # No localhost credential — use remote (phone QR)
                run_unlock_flow "$ttl"
            fi
            ;;
    esac
}

cmd_status() {
    local response
    response=$(send_request '{"method":"status"}')

    local active=$(echo "$response" | jq -r '.data.active // false')
    local remaining=$(echo "$response" | jq -r '.data.remaining // 0')

    if [ "$active" = "true" ]; then
        if [ "$remaining" -lt 0 ] 2>/dev/null; then
            echo -e "${GREEN}Session active (no expiry)${NC}"
        else
            local hours=$((remaining / 3600))
            local mins=$(( (remaining % 3600) / 60 ))
            echo -e "${GREEN}Session active. Expires in ${hours}h ${mins}m.${NC}"
        fi
    else
        echo -e "${YELLOW}Session inactive. Run 'scrt4 unlock' to authenticate.${NC}"
    fi
}

cmd_list() {
    local filter_tag=""
    local show_tags=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tag)  filter_tag="$2"; shift 2 ;;
            --tags) show_tags=true; shift ;;
            *)      shift ;;
        esac
    done

    local response
    response=$(send_request '{"method":"list"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local tags_json
        tags_json=$(_load_tags)
        local names
        names=$(echo "$response" | jq -r '.data.names[]' 2>/dev/null)

        if [ -z "$names" ]; then
            echo -e "${YELLOW}No secrets stored. Add with: scrt4 add KEY=value${NC}"
            return 0
        fi

        # Filter by tag if requested
        if [ -n "$filter_tag" ]; then
            local filtered=""
            while IFS= read -r name; do
                local has_tag
                has_tag=$(printf '%s' "$tags_json" | jq -r --arg k "$name" --arg t "$filter_tag" \
                    '(.[$k] // []) | map(ascii_downcase) | if index($t | ascii_downcase) then "yes" else "no" end')
                if [ "$has_tag" = "yes" ]; then
                    filtered+="${name}"$'\n'
                fi
            done <<< "$names"
            names="${filtered%$'\n'}"
            if [ -z "$names" ]; then
                echo -e "${YELLOW}No secrets with tag '${filter_tag}'.${NC}"
                return 0
            fi
        fi

        local count
        count=$(echo "$names" | wc -l)
        if [ -n "$filter_tag" ]; then
            echo -e "${CYAN}${count} secret(s) tagged '${filter_tag}':${NC}"
        else
            echo -e "${CYAN}${count} secret(s):${NC}"
        fi

        while IFS= read -r name; do
            if [ "$show_tags" = true ] || [ -n "$filter_tag" ]; then
                local t
                t=$(printf '%s' "$tags_json" | jq -r --arg k "$name" '.[$k] // [] | join(", ")')
                if [ -n "$t" ]; then
                    echo "  ${name}  [${t}]"
                else
                    echo "  ${name}"
                fi
            else
                echo "$name"
            fi
        done <<< "$names"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

cmd_run() {
    if [ $# -eq 0 ]; then
        echo -e "${RED}Usage: scrt4 run <command>${NC}" >&2
        return 1
    fi

    local command="$*"
    local json
    json=$(jq -cn --arg cmd "$command" '{method:"run",params:{command:$cmd}}')

    local response
    response=$(send_request "$json" 120)

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local output=$(echo "$response" | jq -r '.data.output // ""')
        local exit_code=$(echo "$response" | jq -r '.data.exit_code // 0')
        printf '%s' "$output"
        return "$exit_code"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

cmd_logout() {
    local response
    response=$(send_request '{"method":"clear"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        echo -e "${GREEN}Session cleared.${NC}"
    else
        echo -e "${RED}Failed to clear session.${NC}" >&2
        return 1
    fi
}

cmd_extend() {
    local ttl="${1:-}"
    local json
    if [ -n "$ttl" ]; then
        json="{\"method\":\"extend\",\"params\":{\"ttl\":$ttl}}"
    else
        json='{"method":"extend"}'
    fi

    local response
    response=$(send_request "$json")

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local remaining=$(echo "$response" | jq -r '.data.remaining // 0')
        local hours=$((remaining / 3600))
        local mins=$(( (remaining % 3600) / 60 ))
        echo -e "${GREEN}Session extended. ${hours}h ${mins}m remaining.${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

cmd_add() {
    if [ $# -eq 0 ]; then
        # ── GUI mode: Zenity notepad ──
        if ! command -v zenity &>/dev/null; then
            echo -e "${RED}Usage: scrt4 add KEY=value [KEY2=value2 ...]${NC}" >&2
            echo -e "${YELLOW}Or install zenity for GUI mode (apt install zenity / brew install zenity)${NC}" >&2
            return 1
        fi

        local tmpfile
        tmpfile=$(mktemp /tmp/scrt4-add-XXXXXX.txt)
        cat > "$tmpfile" << 'PLACEHOLDER'
# Paste your secrets below, one per line
# Format: KEY=value
# Lines starting with # are ignored
# Example:
# API_KEY=sk-abc123
# DB_PASSWORD=mysecretpassword
PLACEHOLDER

        local input
        input=$(zenity --text-info --editable \
            --title="LLM Secrets — Add Secrets" \
            --width=700 --height=500 \
            --font="monospace" \
            --filename="$tmpfile" 2>/dev/null)
        local zenity_rc=$?
        rm -f "$tmpfile"

        if [ $zenity_rc -ne 0 ] || [ -z "$input" ]; then
            echo -e "${YELLOW}Cancelled.${NC}"
            return 0
        fi

        # Parse KEY=value lines
        local json_secrets
        json_secrets=$(printf '%s' "$input" | python3 -c '
import sys, json, re
lines = sys.stdin.read().splitlines()
secrets = {}
skipped = []
for line in lines:
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        continue
    if "=" in stripped:
        key, value = stripped.split("=", 1)
        key = key.strip()
        if key:
            secrets[key] = value
            continue
    if ":" in stripped:
        key, value = stripped.split(":", 1)
        key = key.strip()
        value = value.strip()
        if key and re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", key):
            secrets[key] = value
            continue
    skipped.append(stripped)
for s in skipped:
    print(f"SKIPPED:{s}", file=sys.stderr)
print(f"COUNT:{len(secrets)}", file=sys.stderr)
print(json.dumps(secrets), end="")
' 2>/tmp/scrt4-add-parse.log)

        while IFS= read -r logline; do
            if [[ "$logline" == SKIPPED:* ]]; then
                echo -e "${YELLOW}Skipping: ${logline#SKIPPED:}${NC}" >&2
            fi
        done < /tmp/scrt4-add-parse.log

        local count
        count=$(grep '^COUNT:' /tmp/scrt4-add-parse.log | head -1 | cut -d: -f2)
        rm -f /tmp/scrt4-add-parse.log

        if [ "${count:-0}" -eq 0 ]; then
            echo -e "${YELLOW}No valid KEY=value lines found.${NC}"
            return 0
        fi

        local response
        response=$(send_request "{\"method\":\"add_secrets\",\"params\":{\"secrets\":$json_secrets}}")
        local success=$(echo "$response" | jq -r '.success // false')
        if [ "$success" = "true" ]; then
            local added=$(echo "$response" | jq -r '.data.count // 0')
            echo -e "${GREEN}Added ${added} secret(s).${NC}"
        else
            local error=$(echo "$response" | jq -r '.error // "Unknown error"')
            echo -e "${RED}${error}${NC}" >&2
            return 1
        fi
        return 0
    fi

    # ── CLI mode: KEY=value arguments ──
    local json_secrets="{"
    local first=true
    for pair in "$@"; do
        local key="${pair%%=*}"
        local value="${pair#*=}"
        if [ "$first" = true ]; then
            first=false
        else
            json_secrets+=","
        fi
        value=$(printf '%s' "$value" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()),end="")')
        json_secrets+="\"$key\":$value"
    done
    json_secrets+="}"

    local response
    response=$(send_request "{\"method\":\"add_secrets\",\"params\":{\"secrets\":$json_secrets}}")

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local count=$(echo "$response" | jq -r '.data.count // 0')
        echo -e "${GREEN}Added ${count} secret(s).${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

# ── Tags ─────────────────────────────────────────────────────────────

_load_tags() {
    if [ -f "$TAGS_FILE" ]; then
        cat "$TAGS_FILE"
    else
        echo '{}'
    fi
}

_save_tags() {
    local json="$1"
    mkdir -p "$CONFIG_DIR"
    printf '%s' "$json" > "$TAGS_FILE"
}

_get_tags_for() {
    local name="$1"
    _load_tags | jq -r --arg k "$name" '.[$k] // [] | join(", ")'
}

cmd_tag() {
    if [ $# -lt 2 ]; then
        echo -e "${RED}Usage: scrt4 tag SECRET_NAME tag1 [tag2 ...]${NC}" >&2
        return 1
    fi
    local name="$1"; shift
    local tags_json
    tags_json=$(_load_tags)

    for t in "$@"; do
        tags_json=$(printf '%s' "$tags_json" | jq --arg k "$name" --arg t "$t" \
            '.[$k] = ((.[$k] // []) + [$t] | unique)')
    done

    _save_tags "$tags_json"
    local current
    current=$(printf '%s' "$tags_json" | jq -r --arg k "$name" '.[$k] | join(", ")')
    echo -e "${GREEN}${name}: ${current}${NC}"
    echo -e "${CYAN}Saved to ${TAGS_FILE}${NC}"
}

cmd_untag() {
    if [ $# -lt 2 ]; then
        echo -e "${RED}Usage: scrt4 untag SECRET_NAME tag1 [tag2 ...]${NC}" >&2
        return 1
    fi
    local name="$1"; shift
    local tags_json
    tags_json=$(_load_tags)

    for t in "$@"; do
        tags_json=$(printf '%s' "$tags_json" | jq --arg k "$name" --arg t "$t" \
            'if .[$k] then .[$k] -= [$t] | if .[$k] == [] then del(.[$k]) else . end else . end')
    done

    _save_tags "$tags_json"
    local current
    current=$(printf '%s' "$tags_json" | jq -r --arg k "$name" '.[$k] // [] | join(", ")')
    if [ -z "$current" ]; then
        echo -e "${GREEN}${name}: (no tags)${NC}"
    else
        echo -e "${GREEN}${name}: ${current}${NC}"
    fi
    echo -e "${CYAN}Saved to ${TAGS_FILE}${NC}"
}

cmd_tags() {
    local tags_json
    tags_json=$(_load_tags)
    local count
    count=$(printf '%s' "$tags_json" | jq 'length')
    if [ "${count:-0}" -eq 0 ]; then
        echo -e "${YELLOW}No tags defined. Use: scrt4 tag SECRET_NAME tag1 tag2${NC}"
        return 0
    fi

    echo -e "${CYAN}Tags:${NC}"
    printf '%s' "$tags_json" | jq -r 'to_entries[] | "  \(.key): \(.value | join(", "))"'
}

# ── Import ───────────────────────────────────────────────────────────

cmd_import() {
    local file=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --*) shift ;;     # skip flags
            *)   file="$1"; shift ;;
        esac
    done

    # If no file arg, use file picker
    if [ -z "$file" ]; then
        if ! command -v zenity &>/dev/null; then
            echo -e "${RED}Usage: scrt4 import <file.env>${NC}" >&2
            echo -e "${YELLOW}Or install zenity for file picker (apt install zenity)${NC}" >&2
            return 1
        fi
        file=$(zenity --file-selection \
            --title="LLM Secrets — Import .env File" \
            --file-filter="Env files|*.env *.env.* .env" \
            --file-filter="All files|*" \
            2>/dev/null) || { echo -e "${YELLOW}Cancelled.${NC}"; return 0; }
    fi

    if [ ! -f "$file" ]; then
        echo -e "${RED}File not found: ${file}${NC}" >&2
        return 1
    fi

    # Parse KEY=value lines from the file
    local json_secrets
    json_secrets=$(python3 -c '
import sys, json, re

secrets = {}
skipped = []
for line in open(sys.argv[1]):
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        continue
    # Handle export KEY=value
    if stripped.startswith("export "):
        stripped = stripped[7:].strip()
    if "=" in stripped:
        key, value = stripped.split("=", 1)
        key = key.strip()
        # Strip surrounding quotes from value
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in ("\"", "'\''"):
            value = value[1:-1]
        if key and re.match(r"^[A-Za-z_][A-Za-z0-9_]*$", key):
            secrets[key] = value
            continue
    skipped.append(stripped)
for s in skipped:
    print(f"SKIPPED:{s}", file=sys.stderr)
print(f"COUNT:{len(secrets)}", file=sys.stderr)
print(json.dumps(secrets), end="")
' "$file" 2>/tmp/scrt4-import-parse.log)

    local parse_rc=$?
    if [ $parse_rc -ne 0 ]; then
        echo -e "${RED}Failed to parse file.${NC}" >&2
        rm -f /tmp/scrt4-import-parse.log
        return 1
    fi

    while IFS= read -r logline; do
        if [[ "$logline" == SKIPPED:* ]]; then
            echo -e "${YELLOW}Skipping: ${logline#SKIPPED:}${NC}" >&2
        fi
    done < /tmp/scrt4-import-parse.log

    local count
    count=$(grep '^COUNT:' /tmp/scrt4-import-parse.log | head -1 | cut -d: -f2)
    rm -f /tmp/scrt4-import-parse.log

    if [ "${count:-0}" -eq 0 ]; then
        echo -e "${YELLOW}No valid KEY=value lines found in ${file}.${NC}"
        return 0
    fi

    echo -e "${CYAN}Found ${count} secret(s) in $(basename "$file"). Importing...${NC}"

    ensure_unlocked || return 1

    local response
    response=$(send_request "{\"method\":\"add_secrets\",\"params\":{\"secrets\":$json_secrets}}")
    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local added=$(echo "$response" | jq -r '.data.count // 0')
        echo -e "${GREEN}Imported ${added} secret(s) from $(basename "$file").${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Import failed: ${error}${NC}" >&2
        return 1
    fi
}

# ── View ─────────────────────────────────────────────────────────────

cmd_view() {
    local cli_mode=false
    if [ "${1:-}" = "--cli" ] || [ "$FORCE_CLI" = true ]; then
        cli_mode=true
    fi

    # In GUI mode, require Zenity (secrets displayed in GUI dialog, not terminal)
    if [ "$cli_mode" = false ] && ! command -v zenity &>/dev/null; then
        echo -e "${RED}zenity not found. Use 'scrt4 view --cli' to view in terminal.${NC}" >&2
        echo -e "${YELLOW}Or install zenity (apt install zenity / brew install zenity)${NC}"
        return 1
    fi

    # Ensure vault is unlocked first
    ensure_unlocked || return 1

    # WebAuthn or 6-digit code gate
    _reveal_gate "$cli_mode" || return 1

    # Confirm challenge
    local confirm_json
    confirm_json=$(jq -cn \
        --arg challenge "$_REVEAL_CHALLENGE" \
        --arg code "$_REVEAL_CODE" \
        '{method:"reveal_all_confirm",params:{challenge:$challenge,code:$code}}')

    response=$(send_request "$confirm_json")
    success=$(echo "$response" | jq -r '.success // false')

    if [ "$success" = "true" ]; then
        local count=$(echo "$response" | jq -r '.data.secrets | length // 0')
        if [ "$count" -eq 0 ] 2>/dev/null; then
            echo -e "${YELLOW}No secrets stored. Add with: scrt4 add KEY=value${NC}"
            return 0
        fi

        if [ "$cli_mode" = true ]; then
            echo ""
            echo "$response" | jq -r '.data.secrets | to_entries[] | "\(.key)=\(.value)"'
            echo ""
            response="[CLEARED]"
        else
            local secrets=$(echo "$response" | jq -r '.data.secrets | to_entries[] | "\(.key)=\(.value)"')
            local edited
            edited=$(zenity --text-info --title="LLM Secrets — View All" \
                --editable --width=800 --height=600 \
                --font="monospace" \
                --ok-label="Save" \
                <<< "$secrets" 2>/dev/null) || { secrets="[CLEARED]"; response="[CLEARED]"; return 0; }

            # Parse edited secrets and save them
            if [ -n "$edited" ]; then
                local json_secrets="{"
                local first=true
                local save_count=0
                while IFS= read -r line; do
                    local trimmed=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    # Skip empty lines and comments
                    [[ -z "$trimmed" || "$trimmed" == \#* ]] && continue
                    local key="${trimmed%%=*}"
                    local value="${trimmed#*=}"
                    [[ -z "$key" || "$key" == "$trimmed" ]] && continue
                    if [ "$first" = true ]; then
                        first=false
                    else
                        json_secrets+=","
                    fi
                    value=$(printf '%s' "$value" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()),end="")')
                    json_secrets+="\"$key\":$value"
                    save_count=$((save_count + 1))
                done <<< "$edited"
                json_secrets+="}"

                if [ "$save_count" -gt 0 ]; then
                    local save_response
                    save_response=$(send_request "{\"method\":\"add_secrets\",\"params\":{\"secrets\":$json_secrets}}")
                    local save_success=$(echo "$save_response" | jq -r '.success // false')
                    if [ "$save_success" = "true" ]; then
                        echo -e "${GREEN}Saved ${save_count} secret(s).${NC}"
                    else
                        local save_error=$(echo "$save_response" | jq -r '.error // "Unknown error"')
                        echo -e "${RED}Save failed: ${save_error}${NC}" >&2
                    fi
                fi
            fi
            secrets="[CLEARED]"
            edited="[CLEARED]"
            response="[CLEARED]"
        fi
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        if [ "$cli_mode" = true ]; then
            echo -e "${RED}${error}${NC}" >&2
        else
            zenity --error --text="$error" --width=350 2>/dev/null
        fi
        return 1
    fi
}

cmd_wa_state() {
    local response
    response=$(send_request '{"method":"check_wa_state"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        local configured=$(echo "$response" | jq -r '.data.configured // false')
        local enabled=$(echo "$response" | jq -r '.data.enabled // false')
        local unlock_enabled=$(echo "$response" | jq -r '.data.unlock_enabled // false')

        echo -e "WebAuthn configured:   $([ "$configured" = "true" ] && echo -e "${GREEN}yes${NC}" || echo -e "${YELLOW}no${NC}")"
        echo -e "2FA for reveal/view:   $([ "$enabled" = "true" ] && echo -e "${GREEN}enabled${NC}" || echo -e "${YELLOW}disabled${NC}")"
        echo -e "2FA for unlock:        $([ "$unlock_enabled" = "true" ] && echo -e "${GREEN}enabled${NC}" || echo -e "${YELLOW}disabled${NC}")"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

cmd_wa_off() {
    local method="disable_wa"
    local label="view/reveal"
    if [ "${1:-}" = "--unlock" ]; then
        method="disable_wa_unlock"
        label="unlock"
    fi

    # Require WebAuthn verification before disabling it
    _wa_gate || return 1

    local response
    response=$(send_request "{\"method\":\"${method}\"}")
    local success=$(echo "$response" | jq -r '.success // false')

    if [ "$success" = "true" ]; then
        echo -e "${GREEN}WebAuthn 2FA disabled for ${label}.${NC}"
        if [ "$method" = "disable_wa_unlock" ]; then
            echo -e "${YELLOW}Unlock will use GUI challenge instead of QR code.${NC}"
            echo -e "${YELLOW}Re-enable with: scrt4 wa-on --unlock${NC}"
        else
            echo -e "${YELLOW}View will use GUI challenge only. Re-enable with: scrt4 wa-on${NC}"
        fi
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

cmd_wa_on() {
    local method="enable_wa"
    local label="view/reveal"
    if [ "${1:-}" = "--unlock" ]; then
        method="enable_wa_unlock"
        label="unlock"
    fi

    local response
    response=$(send_request "{\"method\":\"${method}\"}")
    local success=$(echo "$response" | jq -r '.success // false')

    if [ "$success" = "true" ]; then
        echo -e "${GREEN}WebAuthn 2FA re-enabled for ${label}.${NC}"
    else
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${error}${NC}" >&2
        return 1
    fi
}

# ── Folder Encryption ────────────────────────────────────────────────

# File type whitelist for folder encryption
FOLDER_ENCRYPT_EXTENSIONS=".txt .md .pdf .doc .docx .csv .json .yaml .yml .xml .toml .ini .cfg .conf .log .py .js .ts .rs .go .java .c .cpp .h .sh .bash .ps1 .rb .php .sol .abi .pem .key .crt .cer .p12 .pfx .gpg .asc .env .sql .sqlite .db .tar .gz .zip .png .jpg .jpeg .svg .ico .webp"
FOLDER_ENCRYPT_EXCLUDE_DIRS="node_modules target .git __pycache__ .venv dist build"
FOLDER_ENCRYPT_EXCLUDE_EXTS=".exe .dll .so .dylib .bin .mp4 .mov .avi .mp3 .wav .iso .vmdk .qcow2 .scrt4"
FOLDER_ENCRYPT_MAX_SIZE=$((500 * 1024 * 1024))  # 500MB default

cmd_encrypt_folder() {
    local folder_path=""
    local max_size="$FOLDER_ENCRYPT_MAX_SIZE"
    local include_all=false
    local output_dir=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --max-size)
                local size_str="${2:-}"
                if [ -z "$size_str" ]; then
                    echo -e "${RED}--max-size requires a value (e.g., 500M, 1G)${NC}" >&2
                    return 1
                fi
                max_size=$(python3 -c "
import sys, re
s = sys.argv[1].upper()
m = re.match(r'^(\d+(?:\.\d+)?)\s*([KMGT]?)B?$', s)
if not m:
    print('-1')
    sys.exit(0)
val = float(m.group(1))
unit = m.group(2)
mult = {'': 1, 'K': 1024, 'M': 1024**2, 'G': 1024**3, 'T': 1024**4}
print(int(val * mult.get(unit, 1)))
" "$size_str")
                if [ "$max_size" -le 0 ] 2>/dev/null; then
                    echo -e "${RED}Invalid size: ${size_str}${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            --include-all)
                include_all=true
                shift
                ;;
            --output)
                output_dir="${2:-}"
                if [ -z "$output_dir" ]; then
                    echo -e "${RED}--output requires a directory path${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                echo "Usage: scrt4 encrypt-folder <path> [--max-size SIZE] [--include-all] [--output DIR]" >&2
                return 1
                ;;
            *)
                folder_path="$1"
                shift
                ;;
        esac
    done

    if [ -z "$folder_path" ]; then
        echo -e "${RED}Usage: scrt4 encrypt-folder <path> [--max-size SIZE] [--include-all] [--output DIR]${NC}" >&2
        return 1
    fi

    folder_path=$(realpath "$folder_path" 2>/dev/null || echo "$folder_path")

    if [ ! -d "$folder_path" ]; then
        echo -e "${RED}Not a directory: ${folder_path}${NC}" >&2
        return 1
    fi

    local folder_name=$(basename "$folder_path")

    if [ -z "$output_dir" ]; then
        output_dir=$(dirname "$folder_path")
    fi
    local output_file="${output_dir}/${folder_name}.scrt4"

    if [ -f "$output_file" ]; then
        echo -e "${YELLOW}Output file already exists: ${output_file}${NC}"
        read -p "Overwrite? [y/N] " confirm
        if [[ ! "$confirm" =~ ^[Yy] ]]; then
            echo "Cancelled."
            return 0
        fi
    fi

    ensure_unlocked || return 1
    _wa_gate || return 1

    local key_response
    key_response=$(send_request '{"method":"backup_key"}')
    local key_success=$(echo "$key_response" | jq -r '.success // false')
    if [ "$key_success" != "true" ]; then
        local error=$(echo "$key_response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Failed to get master key: ${error}${NC}" >&2
        return 1
    fi
    local master_key=$(echo "$key_response" | jq -r '.data.key')

    echo -e "${CYAN}Encrypting folder: ${folder_name}${NC}"

    local result
    result=$(python3 -c "
import os, sys, json, base64, struct, gzip, tarfile, io, time

folder_path = sys.argv[1]
master_key_b64 = sys.argv[2]
max_size = int(sys.argv[3])
include_all = sys.argv[4] == 'true'
output_file = sys.argv[5]
version_str = sys.argv[6]

master_key = base64.b64decode(master_key_b64)
if len(master_key) != 32:
    print(json.dumps({'error': f'Invalid master key length: {len(master_key)} (expected 32)'}))
    sys.exit(0)

INCLUDE_EXTS = set('${FOLDER_ENCRYPT_EXTENSIONS}'.split())
EXCLUDE_DIRS = set('${FOLDER_ENCRYPT_EXCLUDE_DIRS}'.split())
EXCLUDE_EXTS = set('${FOLDER_ENCRYPT_EXCLUDE_EXTS}'.split())

def should_include(rel_path, is_dir=False):
    if is_dir:
        return os.path.basename(rel_path) not in EXCLUDE_DIRS
    if include_all:
        ext = os.path.splitext(rel_path)[1].lower()
        return ext not in EXCLUDE_EXTS
    ext = os.path.splitext(rel_path)[1].lower()
    if not ext:
        return True
    return ext in INCLUDE_EXTS

files = []
skipped = []
total_size = 0

for root, dirs, filenames in os.walk(folder_path):
    dirs[:] = [d for d in dirs if should_include(d, is_dir=True)]
    for fname in filenames:
        full_path = os.path.join(root, fname)
        rel_path = os.path.relpath(full_path, folder_path)
        if should_include(rel_path):
            try:
                fsize = os.path.getsize(full_path)
                total_size += fsize
                files.append((full_path, rel_path, fsize))
            except OSError:
                skipped.append(rel_path)
        else:
            skipped.append(rel_path)

if not files:
    print(json.dumps({'error': 'No files matched the filter. Use --include-all to include all files.'}))
    sys.exit(0)

if total_size > max_size:
    size_mb = total_size / (1024 * 1024)
    limit_mb = max_size / (1024 * 1024)
    print(json.dumps({'error': f'Folder size ({size_mb:.1f}MB) exceeds limit ({limit_mb:.1f}MB). Use --max-size to increase.'}))
    sys.exit(0)

for s in skipped[:10]:
    print(f'SKIP: {s}', file=sys.stderr)
if len(skipped) > 10:
    print(f'SKIP: ... and {len(skipped) - 10} more', file=sys.stderr)

tar_buffer = io.BytesIO()
with tarfile.open(fileobj=tar_buffer, mode='w:gz') as tar:
    for full_path, rel_path, _ in files:
        tar.add(full_path, arcname=os.path.join(os.path.basename(folder_path), rel_path))

tar_data = tar_buffer.getvalue()

try:
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM
except ImportError:
    import subprocess
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '--user', '-q', 'cryptography'],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM

nonce = os.urandom(12)
salt = os.urandom(16)
aesgcm = AESGCM(master_key)
ciphertext = aesgcm.encrypt(nonce, tar_data, None)

header = json.dumps({
    'folder_name': os.path.basename(folder_path),
    'file_count': len(files),
    'original_size': total_size,
    'created': time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),
    'scrt4_version': version_str,
    'nonce': base64.b64encode(nonce).decode(),
    'salt': base64.b64encode(salt).decode()
}, separators=(',', ':')).encode('utf-8')

with open(output_file, 'wb') as f:
    f.write(b'SCRT4ENC\x00')
    f.write(b'\x01')
    f.write(struct.pack('>I', len(header)))
    f.write(header)
    f.write(ciphertext)

archive_size = os.path.getsize(output_file)
print(json.dumps({
    'success': True,
    'file_count': len(files),
    'skipped_count': len(skipped),
    'original_size': total_size,
    'archive_size': archive_size,
    'output': output_file
}))
" "$folder_path" "$master_key" "$max_size" "$include_all" "$output_file" "$VERSION" 2>&1)

    master_key=""

    local json_line=""
    local skip_lines=""
    while IFS= read -r line; do
        if [[ "$line" == SKIP:* ]]; then
            skip_lines+="  ${YELLOW}${line}${NC}\n"
        elif [[ "$line" == "{"* ]]; then
            json_line="$line"
        fi
    done <<< "$result"

    if [ -n "$skip_lines" ]; then
        echo -e "$skip_lines"
    fi

    if [ -z "$json_line" ]; then
        echo -e "${RED}Encryption failed (no output from Python).${NC}" >&2
        return 1
    fi

    local err=$(echo "$json_line" | jq -r '.error // empty')
    if [ -n "$err" ]; then
        echo -e "${RED}${err}${NC}" >&2
        return 1
    fi

    local file_count=$(echo "$json_line" | jq -r '.file_count')
    local skipped_count=$(echo "$json_line" | jq -r '.skipped_count')
    local original_size=$(echo "$json_line" | jq -r '.original_size')
    local archive_size=$(echo "$json_line" | jq -r '.archive_size')
    local out=$(echo "$json_line" | jq -r '.output')

    local orig_hr=$(numfmt --to=iec-i --suffix=B "$original_size" 2>/dev/null || echo "${original_size} bytes")
    local arch_hr=$(numfmt --to=iec-i --suffix=B "$archive_size" 2>/dev/null || echo "${archive_size} bytes")

    echo -e "${GREEN}Encrypted ${file_count} files (${orig_hr} → ${arch_hr})${NC}"
    if [ "$skipped_count" -gt 0 ]; then
        echo -e "${YELLOW}Skipped ${skipped_count} file(s) (use --include-all to include)${NC}"
    fi
    echo -e "${GREEN}Output: ${out}${NC}"
}

cmd_decrypt_folder() {
    local archive_path=""
    local output_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)
                output_dir="${2:-}"
                if [ -z "$output_dir" ]; then
                    echo -e "${RED}--output requires a directory path${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                echo "Usage: scrt4 decrypt-folder <archive.scrt4> [--output DIR]" >&2
                return 1
                ;;
            *)
                archive_path="$1"
                shift
                ;;
        esac
    done

    if [ -z "$archive_path" ]; then
        echo -e "${RED}Usage: scrt4 decrypt-folder <archive.scrt4> [--output DIR]${NC}" >&2
        return 1
    fi

    archive_path=$(realpath "$archive_path" 2>/dev/null || echo "$archive_path")

    if [ ! -f "$archive_path" ]; then
        echo -e "${RED}File not found: ${archive_path}${NC}" >&2
        return 1
    fi

    if [ -z "$output_dir" ]; then
        output_dir=$(dirname "$archive_path")
    fi

    ensure_unlocked || return 1
    _wa_gate || return 1

    local key_response
    key_response=$(send_request '{"method":"backup_key"}')
    local key_success=$(echo "$key_response" | jq -r '.success // false')
    if [ "$key_success" != "true" ]; then
        local error=$(echo "$key_response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Failed to get master key: ${error}${NC}" >&2
        return 1
    fi
    local master_key=$(echo "$key_response" | jq -r '.data.key')

    echo -e "${CYAN}Decrypting archive...${NC}"

    _decrypt_scrt4_archive "$archive_path" "$master_key" "$output_dir"
    local rc=$?
    master_key=""
    return $rc
}

cmd_recover_folder() {
    local archive_path=""
    local output_dir=""
    local raw_key=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --output)
                output_dir="${2:-}"
                if [ -z "$output_dir" ]; then
                    echo -e "${RED}--output requires a directory path${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            --key)
                raw_key="${2:-}"
                if [ -z "$raw_key" ]; then
                    echo -e "${RED}--key requires a base64 master key${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                echo "Usage: scrt4 recover-folder <archive.scrt4> [--key MASTER_KEY] [--output DIR]" >&2
                return 1
                ;;
            *)
                archive_path="$1"
                shift
                ;;
        esac
    done

    if [ -z "$archive_path" ]; then
        echo -e "${RED}Usage: scrt4 recover-folder <archive.scrt4> [--key MASTER_KEY] [--output DIR]${NC}" >&2
        return 1
    fi

    archive_path=$(realpath "$archive_path" 2>/dev/null || echo "$archive_path")

    if [ ! -f "$archive_path" ]; then
        echo -e "${RED}File not found: ${archive_path}${NC}" >&2
        return 1
    fi

    if [ -z "$output_dir" ]; then
        output_dir=$(dirname "$archive_path")
    fi

    local master_key=""
    if [ -n "$raw_key" ]; then
        master_key="$raw_key"
    else
        ensure_unlocked || return 1
        _wa_gate || return 1

        local key_response
        key_response=$(send_request '{"method":"backup_key"}')
        local key_success=$(echo "$key_response" | jq -r '.success // false')
        if [ "$key_success" != "true" ]; then
            local error=$(echo "$key_response" | jq -r '.error // "Unknown error"')
            echo -e "${RED}Failed to get master key: ${error}${NC}" >&2
            echo -e "${YELLOW}Tip: Use --key <base64-master-key> for offline recovery.${NC}"
            return 1
        fi
        master_key=$(echo "$key_response" | jq -r '.data.key')
    fi

    echo -e "${CYAN}Recovering archive...${NC}"

    _decrypt_scrt4_archive "$archive_path" "$master_key" "$output_dir"
    local rc=$?
    master_key=""
    return $rc
}

# Shared decryption logic for decrypt-folder and recover-folder
_decrypt_scrt4_archive() {
    local archive_path="$1"
    local master_key="$2"
    local output_dir="$3"

    local result
    result=$(python3 -c "
import os, sys, json, base64, struct, gzip, tarfile, io

archive_path = sys.argv[1]
master_key_b64 = sys.argv[2]
output_dir = sys.argv[3]

master_key = base64.b64decode(master_key_b64)
if len(master_key) != 32:
    print(json.dumps({'error': f'Invalid master key length: {len(master_key)} (expected 32)'}))
    sys.exit(0)

with open(archive_path, 'rb') as f:
    magic = f.read(9)
    if magic != b'SCRT4ENC\x00':
        print(json.dumps({'error': 'Invalid archive: bad magic bytes (not a .scrt4 file)'}))
        sys.exit(0)

    version = f.read(1)
    if version != b'\x01':
        print(json.dumps({'error': f'Unsupported archive version: {version[0]}'}))
        sys.exit(0)

    header_len = struct.unpack('>I', f.read(4))[0]
    if header_len > 1024 * 1024:
        print(json.dumps({'error': 'Invalid archive: header too large'}))
        sys.exit(0)

    header_bytes = f.read(header_len)
    ciphertext = f.read()

header = json.loads(header_bytes.decode('utf-8'))
nonce = base64.b64decode(header['nonce'])

try:
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM
except ImportError:
    import subprocess
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '--user', '-q', 'cryptography'],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM

try:
    aesgcm = AESGCM(master_key)
    tar_data = aesgcm.decrypt(nonce, ciphertext, None)
except Exception as e:
    print(json.dumps({'error': f'Decryption failed: wrong key or corrupted archive'}))
    sys.exit(0)

tar_buffer = io.BytesIO(tar_data)
with tarfile.open(fileobj=tar_buffer, mode='r:gz') as tar:
    for member in tar.getmembers():
        if member.name.startswith('/') or '..' in member.name:
            print(json.dumps({'error': f'Archive contains unsafe path: {member.name}'}))
            sys.exit(0)
    tar.extractall(path=output_dir)
    extracted = [m.name for m in tar.getmembers() if m.isfile()]

folder_name = header.get('folder_name', 'unknown')
output_path = os.path.join(output_dir, folder_name)

print(json.dumps({
    'success': True,
    'folder_name': folder_name,
    'file_count': len(extracted),
    'output_path': output_path
}))
" "$archive_path" "$master_key" "$output_dir" 2>&1)

    local json_line=""
    while IFS= read -r line; do
        if [[ "$line" == "{"* ]]; then
            json_line="$line"
        fi
    done <<< "$result"

    if [ -z "$json_line" ]; then
        echo -e "${RED}Decryption failed (no output from Python).${NC}" >&2
        echo "$result" >&2
        return 1
    fi

    local err=$(echo "$json_line" | jq -r '.error // empty')
    if [ -n "$err" ]; then
        echo -e "${RED}${err}${NC}" >&2
        return 1
    fi

    local folder_name=$(echo "$json_line" | jq -r '.folder_name')
    local file_count=$(echo "$json_line" | jq -r '.file_count')
    local output_path=$(echo "$json_line" | jq -r '.output_path')

    echo -e "${GREEN}Decrypted ${file_count} files → ${output_path}${NC}"
}

# ── Backup & Recovery ────────────────────────────────────────────────

cmd_backup_key() {
    local save_dir=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --save)
                if [ -n "${2:-}" ] && [[ "${2:-}" != --* ]]; then
                    save_dir="$2"
                    shift 2
                else
                    save_dir="."
                    shift 1
                fi
                ;;
            *)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                echo "Usage: scrt4 backup-key [--save [directory]]" >&2
                return 1
                ;;
        esac
    done

    # Ensure vault is unlocked first
    ensure_unlocked || return 1

    # WebAuthn gate — master key is highly sensitive
    _wa_gate || return 1

    echo -e "${CYAN}Retrieving master key from daemon...${NC}"

    local response
    response=$(send_request '{"method":"backup_key"}')

    local success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" != "true" ]; then
        local error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}Failed to retrieve master key: ${error}${NC}" >&2
        return 1
    fi

    local key=$(echo "$response" | jq -r '.data.key')

    # No --save: just print the key
    if [ -z "$save_dir" ]; then
        echo -e "${GREEN}Master key retrieved (${#key} characters).${NC}"
        echo ""
        echo -e "${CYAN}Master Key (save this securely!):${NC}"
        echo "$key"
        echo ""
        echo -e "${YELLOW}Store this key in a secure offline location.${NC}"
        echo -e "${YELLOW}Never paste it into Claude Code or any AI agent.${NC}"
        return 0
    fi

    # --save: create password-encrypted backup
    if [ ! -d "$save_dir" ]; then
        echo -e "${RED}Directory not found: ${save_dir}${NC}" >&2
        return 1
    fi
    local abs_save_dir
    abs_save_dir=$(cd "$save_dir" && pwd)

    echo -e "${GREEN}Master key retrieved (${#key} characters).${NC}"
    echo ""
    echo -e "${CYAN}Creating encrypted master key backup...${NC}"
    echo -e "  Destination: ${abs_save_dir}/encrypted-master-key-instructions.json"
    echo -e "  Encryption:  PBKDF2-SHA256 (100k iterations) + AES-256-CBC"
    echo ""
    echo -e "${YELLOW}Choose a recovery password to protect the backup.${NC}"
    echo -e "${YELLOW}You will need this password to recover your master key later.${NC}"
    echo ""
    read -s -p "Recovery password (min 8 chars): " password
    echo
    read -s -p "Confirm password: " password2
    echo

    if [ "$password" != "$password2" ]; then
        echo -e "${RED}Passwords do not match. No file was created.${NC}" >&2
        return 1
    fi

    if [ ${#password} -lt 8 ]; then
        echo -e "${RED}Password must be at least 8 characters. No file was created.${NC}" >&2
        return 1
    fi

    echo ""
    echo -e "${CYAN}Encrypting master key...${NC}"

    local out_file="${abs_save_dir}/encrypted-master-key-instructions.json"
    local encrypt_script=$(mktemp)
    cat > "$encrypt_script" << 'PYEOF'
import json, os, sys, hashlib, base64, subprocess, datetime

lines = sys.stdin.read().split('\n', 1)
master_key, password = lines[0], lines[1]
out_file = sys.argv[1]

salt = os.urandom(16)
iv = os.urandom(16)
derived_key = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000, dklen=32)

proc = subprocess.run(
    ['openssl', 'enc', '-aes-256-cbc',
     '-K', derived_key.hex(), '-iv', iv.hex(), '-nosalt'],
    input=master_key.encode(), capture_output=True)
if proc.returncode != 0:
    print('Encryption failed', file=sys.stderr)
    sys.exit(1)

backup = {
    'Type': 'MasterKeyBackup',
    'Version': '2.0',
    'CreatedAt': datetime.datetime.now().astimezone().isoformat(),
    'SecurityMode': 'webauthn-prf',
    'Salt': base64.b64encode(salt).decode(),
    'IV': base64.b64encode(iv).decode(),
    'EncryptedMasterKey': base64.b64encode(proc.stdout).decode(),
    'DecryptionInstructions': {
        'Algorithm': 'AES-256-CBC',
        'KeyDerivation': 'PBKDF2-SHA256',
        'Iterations': 100000,
        'KeyLength': 32,
        'HowToDecrypt': [
            '1. Run: scrt4 recover encrypted-master-key-instructions.json',
            '2. Enter your recovery password when prompted',
            '3. Your master key will be displayed',
        ],
        'InlineRecoveryScript': (
            '#!/usr/bin/env python3\n'
            'import json, sys, hashlib, base64, subprocess, getpass\n'
            'with open(sys.argv[1], encoding="utf-8-sig") as f: backup = json.load(f)\n'
            'pw = getpass.getpass("Recovery password: ")\n'
            'salt = base64.b64decode(backup["Salt"])\n'
            'iv = base64.b64decode(backup["IV"])\n'
            'enc = base64.b64decode(backup["EncryptedMasterKey"])\n'
            'iters = backup.get("DecryptionInstructions", {}).get("Iterations", 100000)\n'
            'dk = hashlib.pbkdf2_hmac("sha256", pw.encode(), salt, iters, dklen=32)\n'
            'r = subprocess.run(["openssl", "enc", "-aes-256-cbc", "-d",\n'
            '    "-K", dk.hex(), "-iv", iv.hex(), "-nosalt"],\n'
            '    input=enc, capture_output=True)\n'
            'if r.returncode != 0: print("Failed.", file=sys.stderr); sys.exit(1)\n'
            'key = r.stdout.decode().rstrip(chr(0))\n'
            'print(f"Master Key: {key} ({len(key)} chars)")\n'
        )
    }
}

with open(out_file, 'w') as f:
    json.dump(backup, f, indent=2)
print('OK')
PYEOF

    local result
    result=$(printf '%s\n%s' "$key" "$password" | python3 "$encrypt_script" "$out_file")
    local rc=$?
    rm -f "$encrypt_script"

    if [ $rc -ne 0 ] || [ "$result" != "OK" ]; then
        echo -e "${RED}Failed to create encrypted backup.${NC}" >&2
        return 1
    fi

    # Generate recovery instructions
    local readme_file="${abs_save_dir}/RECOVERY-INSTRUCTIONS.txt"
    cat > "$readme_file" << READMEEOF
HOW TO RECOVER YOUR MASTER KEY
==============================
Created: $(date '+%Y-%m-%d %H:%M')

You need TWO things:
  1. The file:  encrypted-master-key-instructions.json  (saved next to this readme)
  2. The password YOU chose when you created the backup


STEP-BY-STEP: GUI (easiest)
────────────────────────────
  1. Run "scrt4" (no arguments) to open the menu
  2. Select "recover"
  3. Select "I set a recovery password and saved a backup file"
  4. Select this file: encrypted-master-key-instructions.json
  5. Type your recovery password
  6. Your master key appears on screen


STEP-BY-STEP: Command Line
───────────────────────────
  1. Run:

       scrt4 recover "${abs_save_dir}/encrypted-master-key-instructions.json"

  2. Type your recovery password
  3. Your master key is displayed


STEP-BY-STEP: Emergency (no LLM Secrets installed)
───────────────────────────────────────────────────
  You only need Python 3 + OpenSSL (any Linux or Mac has these).

  1. Open encrypted-master-key-instructions.json in a text editor
  2. Copy the "InlineRecoveryScript" field into a file called recover.py
     (replace the \\n with actual line breaks)
  3. Run:

       python3 recover.py encrypted-master-key-instructions.json

  4. Type your recovery password
  5. Your master key is displayed


REMEMBER
────────
  • Your recovery password CANNOT be reset. If you forget it,
    this backup is useless.
  • Store the backup file and password in SEPARATE places.
  • The file alone is not enough — it's encrypted with your password.
READMEEOF

    echo ""
    echo -e "${GREEN}Encrypted master key saved!${NC}"
    echo ""
    echo -e "  Backup:       ${out_file}"
    echo -e "  Instructions: ${readme_file}"
    echo -e "  Encrypted:    Yes (AES-256-CBC, password-protected)"
    echo -e "  Raw key:      NOT stored in these files"
    echo ""
    echo -e "${CYAN}To recover later:${NC}"
    echo -e "  scrt4 recover \"${out_file}\""
    echo ""
    echo -e "${YELLOW}Remember your recovery password — it cannot be reset!${NC}"
    echo -e "${YELLOW}Store the files and password in separate secure locations.${NC}"
}

# Shared decryption helper
_decrypt_backup_file() {
    local file="$1" password="$2"
    local script=$(mktemp)
    cat > "$script" << 'PYEOF'
import json, sys, hashlib, base64, subprocess
password = sys.stdin.read()
with open(sys.argv[1], encoding='utf-8-sig') as f:
    backup = json.load(f)
salt = base64.b64decode(backup['Salt'])
iv = base64.b64decode(backup['IV'])
encrypted = base64.b64decode(backup['EncryptedMasterKey'])
iters = backup.get('DecryptionInstructions', {}).get('Iterations', 100000)
derived_key = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, iters, dklen=32)
result = subprocess.run(['openssl', 'enc', '-aes-256-cbc', '-d',
    '-K', derived_key.hex(), '-iv', iv.hex(), '-nosalt'],
    input=encrypted, capture_output=True)
if result.returncode != 0: sys.exit(1)
print(result.stdout.decode().rstrip(chr(0)))
PYEOF
    local key
    key=$(printf '%s' "$password" | python3 "$script" "$file" 2>/dev/null)
    local rc=$?
    rm -f "$script"
    [ $rc -ne 0 ] && return 1
    [ -z "$key" ] && return 1
    echo "$key"
}

cmd_recover() {
    local backup_file="${1:-}"

    # No args: launch GUI wizard
    if [ -z "$backup_file" ]; then
        if command -v zenity &>/dev/null; then
            _recover_wizard
            return $?
        else
            echo -e "${RED}Usage: scrt4 recover <encrypted-master-key-instructions.json>${NC}" >&2
            return 1
        fi
    fi

    # CLI: direct file recovery
    if [ ! -f "$backup_file" ]; then
        echo -e "${RED}File not found: ${backup_file}${NC}" >&2
        return 1
    fi

    echo -e "${CYAN}=== LLM Secrets — Master Key Recovery ===${NC}"
    echo ""

    local created=$(jq -r '.CreatedAt // "unknown"' "$backup_file")
    local version=$(jq -r '.Version // "1.0"' "$backup_file")
    echo -e "  Backup created: ${created}"
    echo -e "  Format version: ${version}"
    echo ""

    read -s -p "Enter recovery password: " password
    echo
    echo ""
    echo -e "${YELLOW}Decrypting...${NC}"

    local master_key
    master_key=$(_decrypt_backup_file "$backup_file" "$password")

    if [ $? -ne 0 ] || [ -z "$master_key" ]; then
        echo -e "${RED}Decryption failed. Check your recovery password.${NC}" >&2
        return 1
    fi

    echo ""
    echo -e "${GREEN}SUCCESS! Your master key:${NC}"
    echo ""
    echo "  $master_key"
    echo ""
    echo -e "  Key length: ${#master_key} characters"
    echo ""
    echo -e "${CYAN}Next steps:${NC}"
    echo -e "  • Re-register WebAuthn:  scrt4 setup"
    echo -e "  • Then add secrets back manually with: scrt4 add KEY=value"
}

# ── Recovery Wizard (GUI) ────────────────────────────────────────────

_recover_wizard() {
    local scenario
    scenario=$(zenity --list \
        --title="LLM Secrets — Recovery" \
        --text="<span font='18' weight='bold'>What do you have?</span>\n\n<span font='11' color='#64748b'>Pick the option that best describes your situation.</span>\n" \
        --column="Scenario" --column="Description" \
        --print-column=1 \
        "have-backup" "I set a recovery password and saved a backup file" \
        "not-sure" "I'm not sure — help me find my backups" \
        "nothing" "I don't have anything" \
        --ok-label="  Next →  " \
        --cancel-label="  ✕  Close  " \
        --width=580 --height=340 2>/dev/null) || return 0

    [ -z "$scenario" ] && return 0

    case "$scenario" in
        "have-backup")    _recover_gui_decrypt_backup ;;
        "not-sure")       _recover_gui_help_find ;;
        "nothing")
            zenity --warning \
                --title="LLM Secrets — Recovery" \
                --text="<span font='14' weight='bold'>Recovery is not possible without a backup</span>\n\n<span font='11'>Without your master key or a backup file, your\nencrypted secrets cannot be recovered.\n\nYou will need to re-create your secrets from scratch.\n\n<b>To prevent this next time:</b>\n  1. From the menu, select <b>backup-key</b> and save the\n     master key in a password manager or on paper\n  2. Select <b>backup-key --save</b> to create a\n     password-protected backup file</span>" \
                --ok-label="  Close  " \
                --width=480 2>/dev/null
            ;;
    esac
}

_recover_gui_decrypt_backup() {
    # Step 1: Pick file
    local file
    file=$(zenity --file-selection \
        --title="Step 1 of 2 — Find your backup file" \
        --file-filter="Backup files|*.json *.backup" 2>/dev/null) || return 0
    [ -z "$file" ] && return 0

    if ! jq -e '.EncryptedMasterKey' "$file" &>/dev/null; then
        zenity --error --title="LLM Secrets" \
            --text="<span font='12' weight='bold'>This doesn't look like a backup file</span>\n\n<span font='11'>The file you selected doesn't contain an\nencrypted master key.\n\nLook for a file named:\n  • <b>encrypted-master-key-instructions.json</b></span>" \
            --width=420 2>/dev/null
        _recover_gui_decrypt_backup
        return $?
    fi

    local created=$(jq -r '.CreatedAt // "unknown"' "$file" 2>/dev/null)

    # Step 2: Enter password
    local password
    password=$(zenity --entry --hide-text \
        --title="Step 2 of 2 — Enter your recovery password" \
        --text="<span font='14' weight='bold'>Enter the password you chose when you created this backup</span>\n\n<span font='11' color='#64748b'>File: $(basename "$file")\nCreated: ${created}</span>\n" \
        --ok-label="  Decrypt →  " \
        --cancel-label="  ← Back  " \
        --width=500 2>/dev/null) || return 0
    [ -z "$password" ] && return 0

    local master_key
    master_key=$(_decrypt_backup_file "$file" "$password")

    if [ $? -ne 0 ] || [ -z "$master_key" ]; then
        zenity --error --title="LLM Secrets — Recovery" \
            --text="<span font='12' weight='bold'>Wrong password</span>\n\n<span font='11'>The password you entered didn't work.\nPlease try again.</span>" \
            --width=380 2>/dev/null
        _recover_gui_decrypt_backup
        return $?
    fi

    # Success
    zenity --info \
        --title="LLM Secrets — Recovery" \
        --text="<span font='14' weight='bold' color='#22c55e'>Success!</span>\n\n<span font='11'>Your master key (${#master_key} characters):</span>\n<span font='13' font_family='monospace' weight='bold'>${master_key}</span>\n\n<span font='11' color='#64748b'>Save this key securely, then re-register:\n  1. Run <b>scrt4 setup</b>\n  2. Re-add your secrets with <b>scrt4 add KEY=value</b></span>" \
        --ok-label="  Done  " \
        --width=540 2>/dev/null
}

