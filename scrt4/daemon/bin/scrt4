# ── Backup Vault ─────────────────────────────────────────────────────

cmd_backup_vault() {
    local local_dest=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --local)
                local_dest="${2:-}"
                if [ -z "$local_dest" ]; then
                    echo -e "${RED}Usage: scrt4 backup-vault --local <path>${NC}" >&2
                    return 1
                fi
                shift 2
                ;;
            *)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                echo "Usage: scrt4 backup-vault [--local <path>]" >&2
                return 1
                ;;
        esac
    done

    local vault_dir="$CONFIG_DIR"
    if [ ! -d "$vault_dir" ]; then
        echo -e "${RED}Config directory not found: ${vault_dir}${NC}" >&2
        return 1
    fi

    # Count vault files
    local file_count=0
    for f in "$vault_dir"/*; do
        [ -f "$f" ] && file_count=$((file_count + 1))
    done

    if [ "$file_count" -eq 0 ]; then
        echo -e "${RED}No vault files found in: ${vault_dir}${NC}" >&2
        return 1
    fi

    local timestamp=$(date +%Y-%m-%d)
    local zip_name="scrt4-backup-${timestamp}.zip"
    local tmp_dir=$(mktemp -d)
    local staging="${tmp_dir}/${zip_name%.zip}"
    local zip_path="${tmp_dir}/${zip_name}"

    echo -e "${CYAN}Backing up vault (${file_count} files)...${NC}"

    mkdir -p "$staging"
    cp -r "$vault_dir"/* "$staging/" 2>/dev/null || true

    (cd "$tmp_dir" && zip -rq "$zip_path" "${zip_name%.zip}/")
    local zip_size=$(stat -c%s "$zip_path" 2>/dev/null || stat -f%z "$zip_path" 2>/dev/null)
    echo -e "${GREEN}Created ${zip_name} (${zip_size} bytes)${NC}"

    if [ -n "$local_dest" ]; then
        if [ ! -d "$local_dest" ]; then
            echo -e "${RED}Directory not found: ${local_dest}${NC}" >&2
            rm -rf "$tmp_dir"
            return 1
        fi
        cp "$zip_path" "${local_dest}/${zip_name}"
        echo -e "${GREEN}Saved to: ${local_dest}/${zip_name}${NC}"
        rm -rf "$tmp_dir"
        return 0
    fi

    # Google Drive upload via scrt run (uses scrt stable for Google credentials)
    echo -e "${CYAN}Uploading to Google Drive...${NC}"

    local upload_script="${tmp_dir}/upload.py"
    cat > "$upload_script" << 'PYEOF'
#!/usr/bin/env python3
"""Upload a file to Google Drive. Reads credentials from stdin."""
import sys, os, json, re, urllib.request, urllib.parse

file_path = sys.argv[1]
file_name = os.path.basename(file_path)

creds_raw = sys.stdin.read().strip()

client_id = re.search(r"client_id:([^,}]+)", creds_raw)
client_secret = re.search(r"client_secret:([^,}]+)", creds_raw)
refresh_token = re.search(r"refresh_token:([^,}]+)", creds_raw)
token_uri = re.search(r"token_uri:([^,}]+)", creds_raw)

if not all([client_id, client_secret, refresh_token, token_uri]):
    print("ERROR: Could not parse credentials", file=sys.stderr)
    sys.exit(1)

client_id = client_id.group(1).strip()
client_secret = client_secret.group(1).strip()
refresh_token = refresh_token.group(1).strip()
token_uri = token_uri.group(1).strip()

data = urllib.parse.urlencode({
    "client_id": client_id, "client_secret": client_secret,
    "refresh_token": refresh_token, "grant_type": "refresh_token"
}).encode()
req = urllib.request.Request(token_uri, data=data, method="POST")
resp = json.loads(urllib.request.urlopen(req).read())
access_token = resp["access_token"]

boundary = "----Scrt4BackupBoundary"
metadata = json.dumps({"name": file_name}).encode()

with open(file_path, "rb") as f:
    file_data = f.read()

body = (
    f"--{boundary}\r\n"
    f"Content-Type: application/json; charset=UTF-8\r\n\r\n"
).encode() + metadata + (
    f"\r\n--{boundary}\r\n"
    f"Content-Type: application/zip\r\n\r\n"
).encode() + file_data + f"\r\n--{boundary}--".encode()

req = urllib.request.Request(
    "https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart",
    data=body,
    headers={
        "Authorization": f"Bearer {access_token}",
        "Content-Type": f"multipart/related; boundary={boundary}",
    },
    method="POST"
)

resp = json.loads(urllib.request.urlopen(req).read())
print(json.dumps({"id": resp["id"], "name": resp["name"]}))
PYEOF

    local result
    result=$(scrt run 'echo "$env[personal_google_workspace]" | python3 '"${upload_script} ${zip_path}" 2>/dev/null)

    if [ $? -ne 0 ] || [ -z "$result" ]; then
        echo -e "${RED}Upload failed. Is personal_google_workspace secret available in scrt?${NC}" >&2
        echo -e "${YELLOW}Backup zip preserved at: ${zip_path}${NC}"
        return 1
    fi

    local file_id=$(echo "$result" | jq -r '.id')
    local file_name_out=$(echo "$result" | jq -r '.name')

    echo -e "${GREEN}Uploaded successfully!${NC}"
    echo -e "  Name: ${file_name_out}"
    echo -e "  Link: ${CYAN}https://drive.google.com/file/d/${file_id}/view${NC}"

    rm -rf "$tmp_dir"
}

# ── Backup Guide ─────────────────────────────────────────────────────

cmd_backup_guide() {
    local guide_file=$(mktemp --suffix=.txt)
    cat > "$guide_file" << 'GUIDE'
╔═══════════════════════════════════════════════════════════════════╗
║              LLM SECRETS — BACKUP & RECOVERY GUIDE               ║
╚═══════════════════════════════════════════════════════════════════╝


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  !! YOUR ONE MANUAL STEP (do this now, never via AI)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  From this menu select "backup-key", or run in your terminal:

    scrt4 backup-key

  Copy the master key. Store it somewhere safe:
    - Printed on paper in a safe / lockbox
    - Password manager (1Password, Bitwarden, etc.)
    - Encrypted USB drive

  !! This key decrypts ALL your secrets. Never paste
  !! it into Claude Code, ChatGPT, or any AI agent.
  !! Everything else below can be automated.


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  COMMAND QUICK REFERENCE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  BACKUP:
    scrt4 backup-vault              Vault → Google Drive
    scrt4 backup-vault --local <dir> Vault → local zip
    scrt4 backup-key                Show raw master key  (USER ONLY)
    scrt4 backup-key --save <dir>   Encrypt key → file   (you type password)

  RECOVERY:
    scrt4 recover <file>            Decrypt key backup   (you type password)

  STATUS:
    scrt4 status                    Check session / daemon
    scrt4 list                      Verify secrets are accessible


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  RECOVERY SCENARIOS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


  SCENARIO 1: Lost WSL / Reinstalled Linux
  ─────────────────────────────────────────
  You have: vault backup zip + master key

    1. Install scrt4 on new WSL instance
    2. Restore vault files to ~/.scrt4/
    3. scrt4 setup  (register new WebAuthn credential)
    4. Re-add secrets with scrt4 add KEY=value


  SCENARIO 2: Forgot Master Key (have backup file + password)
  ──────────────────────────────────────────────────────────
  You have: encrypted-master-key-instructions.json + password

    1. scrt4 recover encrypted-master-key-instructions.json
    2. Type your recovery password
    3. Master key is displayed — save it securely


  SCENARIO 3: Everything Lost
  ───────────────────────────
  Recovery is NOT POSSIBLE. Re-create all secrets from scratch.
  This is why the one step at the top of this guide matters.


GUIDE

    if command -v zenity &>/dev/null; then
        zenity --text-info \
            --title="LLM Secrets — Backup & Recovery Guide" \
            --filename="$guide_file" \
            --editable \
            --ok-label="  Done  " \
            --cancel-label="  ✕  Close  " \
            --width=720 --height=600 \
            --font="monospace 10" 2>/dev/null
    else
        cat "$guide_file"
    fi

    rm -f "$guide_file"
}

# ── Magic Wormhole Share ─────────────────────────────────────────────

_ensure_wormhole() {
    if command -v wormhole &>/dev/null; then
        return 0
    fi
    echo -e "${YELLOW}magic-wormhole is not installed.${NC}"
    echo -n "Install it now? (pip3 install --user magic-wormhole) [y/N] "
    read -r confirm
    if [[ "$confirm" =~ ^[Yy] ]]; then
        echo -e "${CYAN}Installing magic-wormhole...${NC}"
        pip3 install --user magic-wormhole || {
            echo -e "${RED}Installation failed. Install manually: pip3 install --user magic-wormhole${NC}" >&2
            return 1
        }
        if ! command -v wormhole &>/dev/null; then
            echo -e "${RED}wormhole command not found after install. Add ~/.local/bin to PATH.${NC}" >&2
            return 1
        fi
        echo -e "${GREEN}Installed successfully.${NC}"
    else
        echo -e "${YELLOW}Cancelled. Install with: pip3 install --user magic-wormhole${NC}"
        return 1
    fi
}

_share_pick_secrets() {
    local -n _names_ref=$1
    local -n _result_ref=$2
    local use_cli=$3
    local tags_json
    tags_json=$(_load_tags)

    if [ ${#_names_ref[@]} -eq 0 ]; then
        echo -e "${YELLOW}No secrets in vault.${NC}"
        return 1
    fi

    if [ "$use_cli" = false ] && command -v zenity &>/dev/null; then
        # Build zenity checklist args
        local zen_args=()
        for name in "${_names_ref[@]}"; do
            local t
            t=$(printf '%s' "$tags_json" | jq -r --arg k "$name" '.[$k] // [] | join(", ")')
            zen_args+=("FALSE" "$name" "$t")
        done

        local selected
        selected=$(zenity --list --checklist \
            --title="LLM Secrets — Share" \
            --text="<span font='14' weight='bold'>Select secrets to share</span>\n\n<span font='11' color='#64748b'>Selected secrets will be sent via Magic Wormhole</span>\n" \
            --column="Share" --column="Secret Name" --column="Tags" \
            --print-column=2 --separator=$'\n' \
            --ok-label="  Share →  " \
            --cancel-label="  Cancel  " \
            --width=520 --height=450 \
            "${zen_args[@]}" 2>/dev/null) || return 1

        if [ -z "$selected" ]; then
            return 1
        fi

        _result_ref=()
        while IFS= read -r line; do
            [ -n "$line" ] && _result_ref+=("$line")
        done <<< "$selected"
    else
        # CLI fallback: numbered list
        echo ""
        echo -e "${CYAN}Available secrets:${NC}"
        local i=1
        for name in "${_names_ref[@]}"; do
            local t
            t=$(printf '%s' "$tags_json" | jq -r --arg k "$name" '.[$k] // [] | join(", ")')
            if [ -n "$t" ]; then
                printf "  %2d. %s  [%s]\n" "$i" "$name" "$t"
            else
                printf "  %2d. %s\n" "$i" "$name"
            fi
            i=$((i + 1))
        done
        echo ""
        echo -e "Enter numbers (comma/space separated), or ${CYAN}all${NC}:"
        echo -n "> "
        read -r selection

        if [ -z "$selection" ]; then
            return 1
        fi

        _result_ref=()
        if [ "$selection" = "all" ]; then
            _result_ref=("${_names_ref[@]}")
        else
            # Parse comma/space separated numbers
            local nums
            nums=$(echo "$selection" | tr ',;' ' ')
            for num in $nums; do
                if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le ${#_names_ref[@]} ]; then
                    _result_ref+=("${_names_ref[$((num - 1))]}")
                else
                    echo -e "${YELLOW}Skipping invalid: ${num}${NC}" >&2
                fi
            done
        fi
    fi

    if [ ${#_result_ref[@]} -eq 0 ]; then
        echo -e "${YELLOW}No secrets selected.${NC}"
        return 1
    fi
    return 0
}

_share_send() {
    local use_cli=false
    local share_all=false
    local relay_url=""
    local -a named_secrets=()

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cli)    use_cli=true; shift ;;
            --all)    share_all=true; shift ;;
            --relay)  relay_url="${2:-}"; shift 2 ;;
            -*)       shift ;;
            *)        named_secrets+=("$1"); shift ;;
        esac
    done

    if [ "$FORCE_CLI" = true ]; then
        use_cli=true
    fi

    _ensure_wormhole || return 1
    ensure_unlocked || return 1

    # Get secret names from daemon
    local list_response
    list_response=$(send_request '{"method":"list"}')
    local list_ok=$(echo "$list_response" | jq -r '.success // false')
    if [ "$list_ok" != "true" ]; then
        local err=$(echo "$list_response" | jq -r '.error // "Unknown error"')
        echo -e "${RED}${err}${NC}" >&2
        return 1
    fi

    local -a all_names=()
    while IFS= read -r n; do
        [ -n "$n" ] && all_names+=("$n")
    done < <(echo "$list_response" | jq -r '.data.names[]' 2>/dev/null)

    if [ ${#all_names[@]} -eq 0 ]; then
        echo -e "${YELLOW}No secrets in vault. Nothing to share.${NC}"
        return 0
    fi

    # Determine which secrets to share
    local -a selected=()
    if [ "$share_all" = true ]; then
        selected=("${all_names[@]}")
    elif [ ${#named_secrets[@]} -gt 0 ]; then
        # Validate named secrets
        for name in "${named_secrets[@]}"; do
            local found=false
            for n in "${all_names[@]}"; do
                if [ "$n" = "$name" ]; then
                    found=true
                    break
                fi
            done
            if [ "$found" = true ]; then
                selected+=("$name")
            else
                echo -e "${YELLOW}Warning: '${name}' not found in vault, skipping.${NC}" >&2
            fi
        done
    else
        # Interactive picker
        _share_pick_secrets all_names selected "$use_cli" || return 0
    fi

    if [ ${#selected[@]} -eq 0 ]; then
        echo -e "${YELLOW}No valid secrets to share.${NC}"
        return 0
    fi

    echo -e "${CYAN}Sharing ${#selected[@]} secret(s): ${selected[*]}${NC}"

    # WebAuthn gate + reveal_all challenge (issue #35).
    # _reveal_gate runs _wa_gate (passkey) then requests the challenge; the
    # 6-digit code is auto-used since WebAuthn already authorized the reveal.
    _reveal_gate "$use_cli" || return 1
    local challenge="$_REVEAL_CHALLENGE"
    local user_code="$_REVEAL_CODE"

    # Use temp dir in RAM-backed tmpfs
    local tmp_dir="${XDG_RUNTIME_DIR:-/tmp}"
    local encrypted_file="${tmp_dir}/scrt4-share-$$.bin"

    # Python script: confirm challenge → get secrets → encrypt → write file
    # Secret values ONLY exist in Python memory, never in bash
    local py_result
    py_result=$(python3 -c '
import socket, json, sys, os, base64

challenge = sys.argv[1]
user_code = sys.argv[2]
sock_path = sys.argv[3]
output_path = sys.argv[4]
selected_json = sys.argv[5]

selected = json.loads(selected_json)

# Connect to daemon and send reveal_all_confirm
def send_daemon(method_json):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(10)
    s.connect(sock_path)
    data = json.dumps(method_json).encode() + b"\n"
    s.sendall(data)
    s.shutdown(socket.SHUT_WR)
    chunks = []
    while True:
        try:
            d = s.recv(65536)
            if not d: break
            chunks.append(d)
        except: break
    s.close()
    return json.loads(b"".join(chunks))

confirm_req = {
    "method": "reveal_all_confirm",
    "params": {"challenge": challenge, "code": user_code}
}
resp = send_daemon(confirm_req)

if not resp.get("success"):
    error = resp.get("error", "Unknown error")
    print(json.dumps({"error": error}))
    sys.exit(0)

all_secrets = resp.get("data", {}).get("secrets", {})

# Filter to selected names only
payload = {}
for name in selected:
    if name in all_secrets:
        payload[name] = all_secrets[name]

# Clear all_secrets from memory
for k in list(all_secrets.keys()):
    all_secrets[k] = "[CLEARED]"
del all_secrets

if not payload:
    print(json.dumps({"error": "No matching secrets found"}))
    sys.exit(0)

plaintext = json.dumps(payload, separators=(",", ":")).encode("utf-8")

# Clear payload dict
for k in list(payload.keys()):
    payload[k] = "[CLEARED]"
del payload

# Encrypt with ephemeral AES-256-GCM key
try:
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM
except ImportError:
    import subprocess
    subprocess.check_call([sys.executable, "-m", "pip", "install", "--user", "-q", "cryptography"],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM

ephemeral_key = os.urandom(32)
nonce = os.urandom(12)
aesgcm = AESGCM(ephemeral_key)
ciphertext = aesgcm.encrypt(nonce, plaintext, None)

# Clear plaintext from memory
plaintext = b"[CLEARED]"
del plaintext

# Build file: MAGIC + \0 + base64(key) + \0 + nonce + ciphertext
key_b64 = base64.b64encode(ephemeral_key)  # already bytes, 44 bytes
ephemeral_key = b"[CLEARED]"

# Write with secure permissions (O_CREAT|O_EXCL|O_WRONLY, 0o600)
fd = os.open(output_path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
with os.fdopen(fd, "wb") as f:
    f.write(b"SCRT4SHARE\x00")  # 11 bytes
    f.write(key_b64)             # 44 bytes
    f.write(b"\x00")             # 1 byte
    f.write(nonce)               # 12 bytes
    f.write(ciphertext)          # variable

key_b64 = b"[CLEARED]"

count = len(json.loads("{}"))  # not useful, use selected count
print(json.dumps({"success": True, "count": len(selected), "file": output_path}))
' "$challenge" "$user_code" "$SOCKET" "$encrypted_file" "$(printf '%s\n' "${selected[@]}" | jq -R . | jq -sc .)" 2>&1)

    # Parse python result
    local py_json=""
    while IFS= read -r line; do
        if [[ "$line" == "{"* ]]; then
            py_json="$line"
        fi
    done <<< "$py_result"

    if [ -z "$py_json" ]; then
        echo -e "${RED}Encryption failed (no output from Python).${NC}" >&2
        echo "$py_result" >&2
        rm -f "$encrypted_file"
        return 1
    fi

    local py_err=$(echo "$py_json" | jq -r '.error // empty')
    if [ -n "$py_err" ]; then
        echo -e "${RED}${py_err}${NC}" >&2
        rm -f "$encrypted_file"
        return 1
    fi

    local share_count=$(echo "$py_json" | jq -r '.count')
    echo -e "${GREEN}Encrypted ${share_count} secret(s). Starting wormhole transfer...${NC}"

    # Relay privacy warning (first use)
    if [ -z "$relay_url" ]; then
        echo -e "${YELLOW}Note: Using public relay (relay.magic-wormhole.io). Your IP is visible to the relay operator.${NC}"
        echo -e "${YELLOW}Use --relay URL to self-host.${NC}"
    fi

    # Run wormhole send (interactive — displays wormhole code to user).
    #
    # Wormhole prints its own hint: "On the other computer, please run:
    # wormhole receive CODE". We rewrite that line so the receiver is told
    # to run `scrt4 receive --code CODE` instead — the scrt4 command
    # handles decryption and import in one step; the raw `wormhole receive`
    # command would just save the encrypted blob.
    #
    # All of wormhole's interactive output (code, QR, progress bar) is on
    # stderr, so we pipe stderr through awk and leave stdout alone.
    # fflush() keeps each line visible in real time.
    local wormhole_args=("send" "$encrypted_file")
    if [ -n "$relay_url" ]; then
        wormhole_args=("--relay-url" "$relay_url" "send" "$encrypted_file")
    fi

    wormhole "${wormhole_args[@]}" 2> >(awk '
        /^On the other computer, please run:/ {
            print "On the other computer, run:"
            fflush()
            next
        }
        /^wormhole receive / {
            print "  scrt4 receive --code " $NF
            fflush()
            next
        }
        { print; fflush() }
    ' >&2)
    local wh_rc=$?

    # Shred and clean up temp file
    if [ -f "$encrypted_file" ]; then
        local fsize
        fsize=$(stat -c%s "$encrypted_file" 2>/dev/null || stat -f%z "$encrypted_file" 2>/dev/null || echo 0)
        if [ "$fsize" -gt 0 ] 2>/dev/null; then
            dd if=/dev/urandom of="$encrypted_file" bs=1 count="$fsize" conv=notrunc 2>/dev/null
            sync "$encrypted_file" 2>/dev/null
        fi
        rm -f "$encrypted_file"
    fi

    if [ $wh_rc -ne 0 ]; then
        echo -e "${RED}Wormhole transfer failed.${NC}" >&2
        return 1
    fi

    echo -e "${GREEN}Transfer complete! ${share_count} secret(s) sent.${NC}"
}

_share_receive() {
    local use_cli=false
    local wormhole_code=""
    local relay_url=""

    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cli)    use_cli=true; shift ;;
            --code)   wormhole_code="${2:-}"; shift 2 ;;
            --relay)  relay_url="${2:-}"; shift 2 ;;
            -*)       shift ;;
            *)        wormhole_code="$1"; shift ;;
        esac
    done

    if [ "$FORCE_CLI" = true ]; then
        use_cli=true
    fi

    _ensure_wormhole || return 1
    ensure_unlocked || return 1

    # Get wormhole code if not provided
    if [ -z "$wormhole_code" ]; then
        if [ "$use_cli" = false ] && command -v zenity &>/dev/null; then
            wormhole_code=$(zenity --entry \
                --title="LLM Secrets — Receive" \
                --text="<span font='14' weight='bold'>Enter the wormhole code</span>\n\n<span font='11' color='#64748b'>The sender will show you a code like: 7-crossover-headline</span>\n" \
                --ok-label="  Receive →  " \
                --cancel-label="  Cancel  " \
                --width=450 2>/dev/null) || { echo -e "${YELLOW}Cancelled.${NC}"; return 0; }
        else
            echo ""
            echo -n "  Enter wormhole code: "
            read -r wormhole_code
        fi
    fi

    if [ -z "$wormhole_code" ]; then
        echo -e "${YELLOW}Cancelled.${NC}"
        return 0
    fi

    # Receive to temp file in RAM-backed tmpfs
    local tmp_dir="${XDG_RUNTIME_DIR:-/tmp}"
    local encrypted_file="${tmp_dir}/scrt4-share-recv-$$.bin"

    echo -e "${CYAN}Receiving via wormhole...${NC}"

    # Relay privacy note
    if [ -z "$relay_url" ]; then
        echo -e "${YELLOW}Note: Using public relay (relay.magic-wormhole.io). Your IP is visible to the relay operator.${NC}"
    fi

    local wormhole_args=("receive" "--accept-file" "-o" "$encrypted_file" "$wormhole_code")
    if [ -n "$relay_url" ]; then
        wormhole_args=("--relay-url" "$relay_url" "receive" "--accept-file" "-o" "$encrypted_file" "$wormhole_code")
    fi

    wormhole "${wormhole_args[@]}"
    local wh_rc=$?

    if [ $wh_rc -ne 0 ] || [ ! -f "$encrypted_file" ]; then
        echo -e "${RED}Wormhole receive failed.${NC}" >&2
        rm -f "$encrypted_file"
        return 1
    fi

    echo -e "${GREEN}File received. Decrypting...${NC}"

    # Python script phase 1: decrypt → extract names → print names to stdout, wait for confirmation
    # Secret values stay in Python memory; bash only sees names
    local py_names
    py_names=$(python3 -c '
import os, sys, json, base64

input_path = sys.argv[1]

with open(input_path, "rb") as f:
    data = f.read()

# Validate magic
if len(data) < 68 or data[:11] != b"SCRT4SHARE\x00":
    print(json.dumps({"error": "Invalid share file (bad magic bytes)"}))
    sys.exit(0)

# Parse: magic(11) + key_b64(44) + \0(1) + nonce(12) + ciphertext(variable)
key_b64 = data[11:55]
if data[55:56] != b"\x00":
    print(json.dumps({"error": "Invalid share file (malformed header)"}))
    sys.exit(0)

nonce = data[56:68]
ciphertext = data[68:]

try:
    ephemeral_key = base64.b64decode(key_b64)
except Exception:
    print(json.dumps({"error": "Invalid share file (bad key encoding)"}))
    sys.exit(0)

if len(ephemeral_key) != 32:
    print(json.dumps({"error": "Invalid share file (wrong key length)"}))
    sys.exit(0)

try:
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM
except ImportError:
    import subprocess
    subprocess.check_call([sys.executable, "-m", "pip", "install", "--user", "-q", "cryptography"],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM

try:
    aesgcm = AESGCM(ephemeral_key)
    plaintext = aesgcm.decrypt(nonce, ciphertext, None)
except Exception:
    print(json.dumps({"error": "Decryption failed — corrupted or tampered transfer"}))
    sys.exit(0)

ephemeral_key = b"[CLEARED]"

try:
    secrets = json.loads(plaintext)
except Exception:
    print(json.dumps({"error": "Invalid payload (not valid JSON)"}))
    sys.exit(0)

names = list(secrets.keys())

# Clear secrets from memory for this phase
for k in list(secrets.keys()):
    secrets[k] = "[CLEARED]"
del secrets
plaintext = b"[CLEARED]"

print(json.dumps({"success": True, "names": names, "count": len(names)}))
' "$encrypted_file" 2>&1)

    local names_json=""
    while IFS= read -r line; do
        if [[ "$line" == "{"* ]]; then
            names_json="$line"
        fi
    done <<< "$py_names"

    if [ -z "$names_json" ]; then
        echo -e "${RED}Decryption failed (no output from Python).${NC}" >&2
        # Shred temp file
        _shred_file "$encrypted_file"
        return 1
    fi

    local names_err=$(echo "$names_json" | jq -r '.error // empty')
    if [ -n "$names_err" ]; then
        echo -e "${RED}${names_err}${NC}" >&2
        _shred_file "$encrypted_file"
        return 1
    fi

    local recv_count=$(echo "$names_json" | jq -r '.count')
    local names_list
    names_list=$(echo "$names_json" | jq -r '.names[]')

    echo ""
    echo -e "${CYAN}Received ${recv_count} secret(s):${NC}"
    while IFS= read -r name; do
        echo "  $name"
    done <<< "$names_list"
    echo ""

    # Confirm import. Use GUI only when a display is actually reachable —
    # `command -v zenity` alone would succeed in the hardened Docker image
    # (which installs zenity) and then zenity itself would fail silently on
    # the missing DISPLAY, leaving confirmed=false and cancelling the import.
    local confirmed=false
    if [ "$use_cli" = false ] && _has_gui; then
        zenity --question \
            --title="LLM Secrets — Import Received Secrets" \
            --text="<span font='14' weight='bold'>Import ${recv_count} secret(s)?</span>\n\n<span font='11' font_family='monospace'>$(echo "$names_list" | head -20)</span>\n\n<span font='11' color='#64748b'>These will be added to your vault.\nExisting secrets with the same name will be overwritten.</span>" \
            --ok-label="  Import  " \
            --cancel-label="  Cancel  " \
            --width=450 2>/dev/null && confirmed=true
    else
        # Default to YES: the user already ran `scrt4 receive` and watched
        # the transfer happen. Anything other than an explicit N/n imports.
        echo -n "Import these secrets into your vault? [Y/n] "
        read -r confirm
        [[ "$confirm" =~ ^[Nn] ]] || confirmed=true
    fi

    if [ "$confirmed" != true ]; then
        echo -e "${YELLOW}Cancelled. No secrets imported.${NC}"
        _shred_file "$encrypted_file"
        return 0
    fi

    # Python phase 2: re-decrypt file → send to daemon via add_secrets
    local py_import
    py_import=$(python3 -c '
import os, sys, json, base64, socket

input_path = sys.argv[1]
sock_path = sys.argv[2]

with open(input_path, "rb") as f:
    data = f.read()

key_b64 = data[11:55]
nonce = data[56:68]
ciphertext = data[68:]
ephemeral_key = base64.b64decode(key_b64)

from cryptography.hazmat.primitives.ciphers.aead import AESGCM

aesgcm = AESGCM(ephemeral_key)
plaintext = aesgcm.decrypt(nonce, ciphertext, None)
ephemeral_key = b"[CLEARED]"

secrets = json.loads(plaintext)
plaintext = b"[CLEARED]"

# Send to daemon via Unix socket
req = {"method": "add_secrets", "params": {"secrets": secrets}}
req_bytes = json.dumps(req).encode() + b"\n"

# Clear secrets from memory
for k in list(secrets.keys()):
    secrets[k] = "[CLEARED]"
del secrets

s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(10)
s.connect(sock_path)
s.sendall(req_bytes)
s.shutdown(socket.SHUT_WR)
chunks = []
while True:
    try:
        d = s.recv(65536)
        if not d: break
        chunks.append(d)
    except: break
s.close()

resp = json.loads(b"".join(chunks))
if resp.get("success"):
    count = resp.get("data", {}).get("count", 0)
    print(json.dumps({"success": True, "count": count}))
else:
    print(json.dumps({"error": resp.get("error", "Unknown error")}))
' "$encrypted_file" "$SOCKET" 2>&1)

    # Shred temp file immediately
    _shred_file "$encrypted_file"

    local import_json=""
    while IFS= read -r line; do
        if [[ "$line" == "{"* ]]; then
            import_json="$line"
        fi
    done <<< "$py_import"

    if [ -z "$import_json" ]; then
        echo -e "${RED}Import failed (no output from Python).${NC}" >&2
        return 1
    fi

    local import_err=$(echo "$import_json" | jq -r '.error // empty')
    if [ -n "$import_err" ]; then
        echo -e "${RED}Import failed: ${import_err}${NC}" >&2
        return 1
    fi

    local imported_count=$(echo "$import_json" | jq -r '.count')
    echo -e "${GREEN}Imported ${imported_count} secret(s) into vault.${NC}"
}

_shred_file() {
    local file="$1"
    if [ -f "$file" ]; then
        local fsize
        fsize=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null || echo 0)
        if [ "$fsize" -gt 0 ] 2>/dev/null; then
            dd if=/dev/urandom of="$file" bs=1 count="$fsize" conv=notrunc 2>/dev/null
            sync "$file" 2>/dev/null
        fi
        rm -f "$file"
    fi
}

cmd_share() {
    local is_receive=false
    local -a passthrough=()

    # Check for --receive flag (first pass)
    for arg in "$@"; do
        if [ "$arg" = "--receive" ]; then
            is_receive=true
        else
            passthrough+=("$arg")
        fi
    done

    if [ "$is_receive" = true ]; then
        _share_receive "${passthrough[@]}"
    else
        _share_send "$@"
    fi
}

# ── Wallet Dashboard ─────────────────────────────────────────────────

_wallet_detect_secrets() {
    # Categorize secret names by pattern. Input: newline-separated names on stdin.
    python3 -c '
import sys, json, re
names = [n.strip() for n in sys.stdin.read().splitlines() if n.strip()]
# Only match public keys/addresses — exclude private keys, mnemonics, secrets
wallets = [n for n in names
    if re.search(r"PUBLIC.?KEY|ADDRESS", n, re.I)
    and not re.search(r"PRIVATE|MNEMONIC|SECRET|TOKEN|API|RPC|URL", n, re.I)]
rpcs = [n for n in names if re.search(r"RPC|ALCHEMY.*URL|INFURA", n, re.I)]
etherscan = [n for n in names if re.search(r"ETHERSCAN", n, re.I)]
print(json.dumps({"wallets": wallets, "rpcs": rpcs, "etherscan": etherscan}))
'
}

_wallet_setup() {
    local use_cli=false
    if [ "$FORCE_CLI" = true ] || [ "${1:-}" = "--cli" ]; then
        use_cli=true
    fi

    # Get secret names
    local list_response
    list_response=$(send_request '{"method":"list"}')
    local list_ok=$(echo "$list_response" | jq -r '.success // false')
    if [ "$list_ok" != "true" ]; then
        echo -e "${RED}Cannot list secrets. Is vault initialized?${NC}" >&2
        return 1
    fi

    local all_names
    all_names=$(echo "$list_response" | jq -r '.data.names[]' 2>/dev/null)
    if [ -z "$all_names" ]; then
        echo -e "${YELLOW}No secrets in vault. Add secrets first, then run wallet setup.${NC}"
        return 1
    fi

    # Detect categories
    local detected
    detected=$(echo "$all_names" | _wallet_detect_secrets)
    local -a det_wallets=() det_rpcs=() det_etherscan=()

    while IFS= read -r w; do [ -n "$w" ] && det_wallets+=("$w"); done < <(echo "$detected" | jq -r '.wallets[]' 2>/dev/null)
    while IFS= read -r r; do [ -n "$r" ] && det_rpcs+=("$r"); done < <(echo "$detected" | jq -r '.rpcs[]' 2>/dev/null)
    while IFS= read -r e; do [ -n "$e" ] && det_etherscan+=("$e"); done < <(echo "$detected" | jq -r '.etherscan[]' 2>/dev/null)

    if [ ${#det_wallets[@]} -eq 0 ]; then
        echo -e "${YELLOW}No wallet-like secrets detected (looking for PUBLIC_KEY, WALLET, ADDRESS).${NC}"
        echo -e "${YELLOW}Add wallet address secrets, then re-run: scrt4 wallet setup${NC}"
        return 1
    fi

    if [ ${#det_rpcs[@]} -eq 0 ]; then
        echo -e "${YELLOW}No RPC URL secrets detected. Add one (e.g., ALCHEMY_RPC_URL) and try again.${NC}"
        return 1
    fi

    local -a selected_wallets=()
    local selected_rpc=""
    local selected_etherscan=""

    if [ "$use_cli" = false ] && command -v zenity &>/dev/null; then
        # ── Step 1: Pick wallets (checklist) ──
        local zen_args=()
        for w in "${det_wallets[@]}"; do
            zen_args+=("TRUE" "$w")
        done

        local picked
        picked=$(zenity --list --checklist \
            --title="Wallet Setup — Step 1/3: Wallets" \
            --text="<span font='14' weight='bold'>Select wallets to track</span>\n\n<span font='11' color='#64748b'>These secrets should contain public addresses (0x...)</span>\n" \
            --column="Track" --column="Secret Name" \
            --print-column=2 --separator=$'\n' \
            --ok-label="  Next →  " \
            --cancel-label="  Cancel  " \
            --width=450 --height=380 \
            "${zen_args[@]}" 2>/dev/null) || { echo -e "${YELLOW}Cancelled.${NC}"; return 0; }

        while IFS= read -r line; do
            [ -n "$line" ] && selected_wallets+=("$line")
        done <<< "$picked"

        if [ ${#selected_wallets[@]} -eq 0 ]; then
            echo -e "${YELLOW}No wallets selected.${NC}"
            return 0
        fi

        # ── Step 2: Pick RPC (single selection) ──
        local rpc_args=()
        for r in "${det_rpcs[@]}"; do
            rpc_args+=("$r")
        done

        selected_rpc=$(zenity --list \
            --title="Wallet Setup — Step 2/3: RPC Provider" \
            --text="<span font='14' weight='bold'>Select RPC endpoint</span>\n\n<span font='11' color='#64748b'>Used to query blockchain balances</span>\n" \
            --column="Secret Name" \
            --ok-label="  Next →  " \
            --cancel-label="  Cancel  " \
            --width=450 --height=320 \
            "${rpc_args[@]}" 2>/dev/null) || { echo -e "${YELLOW}Cancelled.${NC}"; return 0; }

        # ── Step 3: Etherscan API key (optional) ──
        if [ ${#det_etherscan[@]} -gt 0 ]; then
            local eth_args=("(none)")
            for e in "${det_etherscan[@]}"; do
                eth_args+=("$e")
            done
            selected_etherscan=$(zenity --list \
                --title="Wallet Setup — Step 3/3: Block Explorer API" \
                --text="<span font='14' weight='bold'>Select Etherscan API key (optional)</span>\n\n<span font='11' color='#64748b'>Enables transaction history. Select (none) to skip.</span>\n" \
                --column="Secret Name" \
                --ok-label="  Done  " \
                --cancel-label="  Cancel  " \
                --width=450 --height=320 \
                "${eth_args[@]}" 2>/dev/null) || { echo -e "${YELLOW}Cancelled.${NC}"; return 0; }
            [ "$selected_etherscan" = "(none)" ] && selected_etherscan=""
        fi
    else
        # ── CLI setup ──
        echo ""
        echo -e "${CYAN}Wallet Setup${NC}"
        echo ""

        # Wallets
        echo -e "${CYAN}Detected wallet secrets:${NC}"
        local i=1
        for w in "${det_wallets[@]}"; do
            printf "  %2d. %s\n" "$i" "$w"
            i=$((i + 1))
        done
        echo ""
        echo -e "Select wallets (numbers, comma-separated, or ${CYAN}all${NC}):"
        echo -n "> "
        read -r wsel
        if [ "$wsel" = "all" ] || [ -z "$wsel" ]; then
            selected_wallets=("${det_wallets[@]}")
        else
            for num in $(echo "$wsel" | tr ',; ' ' '); do
                if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le ${#det_wallets[@]} ]; then
                    selected_wallets+=("${det_wallets[$((num - 1))]}")
                fi
            done
        fi

        # RPC
        echo ""
        echo -e "${CYAN}Detected RPC secrets:${NC}"
        i=1
        for r in "${det_rpcs[@]}"; do
            printf "  %2d. %s\n" "$i" "$r"
            i=$((i + 1))
        done
        echo -n "Select RPC [1]: "
        read -r rsel
        rsel="${rsel:-1}"
        if [[ "$rsel" =~ ^[0-9]+$ ]] && [ "$rsel" -ge 1 ] && [ "$rsel" -le ${#det_rpcs[@]} ]; then
            selected_rpc="${det_rpcs[$((rsel - 1))]}"
        else
            selected_rpc="${det_rpcs[0]}"
        fi

        # Etherscan
        if [ ${#det_etherscan[@]} -gt 0 ]; then
            echo ""
            echo -e "${CYAN}Detected Etherscan API keys:${NC}"
            i=1
            for e in "${det_etherscan[@]}"; do
                printf "  %2d. %s\n" "$i" "$e"
                i=$((i + 1))
            done
            echo -n "Select Etherscan key (enter to skip) [1]: "
            read -r esel
            if [ -n "$esel" ] && [[ "$esel" =~ ^[0-9]+$ ]] && [ "$esel" -ge 1 ] && [ "$esel" -le ${#det_etherscan[@]} ]; then
                selected_etherscan="${det_etherscan[$((esel - 1))]}"
            elif [ -z "$esel" ]; then
                selected_etherscan="${det_etherscan[0]}"
            fi
        fi
    fi

    # Build wallet config JSON
    local wallets_json="["
    local first=true
    for w in "${selected_wallets[@]}"; do
        if [ "$first" = true ]; then first=false; else wallets_json+=","; fi
        local label
        # Derive a human label from the secret name
        label=$(echo "$w" | sed 's/_/ /g; s/PUBLIC KEY/Wallet/i; s/PHANTOM WALLET/Phantom/i')
        wallets_json+="{\"label\":$(printf '%s' "$label" | jq -Rs .),\"secret\":$(printf '%s' "$w" | jq -Rs .)}"
    done
    wallets_json+="]"

    local config_json
    config_json=$(jq -cn \
        --arg rpc "$selected_rpc" \
        --arg etherscan "$selected_etherscan" \
        --argjson wallets "$wallets_json" \
        '{rpc: $rpc, etherscan: $etherscan, wallets: $wallets}')

    mkdir -p "$CONFIG_DIR"
    printf '%s' "$config_json" | jq . > "$WALLET_CONFIG"

    echo -e "${GREEN}Wallet config saved to ${WALLET_CONFIG}${NC}"
    echo -e "  RPC: ${selected_rpc}"
    [ -n "$selected_etherscan" ] && echo -e "  Etherscan: ${selected_etherscan}"
    echo -e "  Wallets: ${#selected_wallets[@]}"
    echo -e "${CYAN}Run 'scrt4 wallet' to view dashboard.${NC}"
}

_wallet_display() {
    local use_cli=false
    if [ "$FORCE_CLI" = true ] || [ "${1:-}" = "--cli" ]; then
        use_cli=true
    fi

    # Load config or run setup
    if [ ! -f "$WALLET_CONFIG" ]; then
        echo -e "${YELLOW}Wallet not configured. Running setup...${NC}"
        _wallet_setup "$@" || return 1
        [ ! -f "$WALLET_CONFIG" ] && return 1
    fi

    local config
    config=$(cat "$WALLET_CONFIG")

    # Auto-sync: detect new wallet secrets and add them to config
    ensure_unlocked || return 1
    local all_names
    all_names=$(send_request '{"method":"list"}' | jq -r '.data.names[]' 2>/dev/null)
    if [ -n "$all_names" ]; then
        local detected
        detected=$(echo "$all_names" | _wallet_detect_secrets)
        local sync_result
        sync_result=$(python3 -c '
import json, sys
config = json.loads(sys.argv[1])
detected = json.loads(sys.argv[2])
existing = {w["secret"] for w in config.get("wallets", [])}
new_wallets = [w for w in detected.get("wallets", []) if w not in existing]
if not new_wallets:
    print(json.dumps({"changed": False}))
else:
    for w in new_wallets:
        label = w.replace("_PUBLIC_KEY", "").replace("PUBLIC_KEY", "Main Wallet").replace("_", " ").title()
        if not label.strip():
            label = w
        config["wallets"].append({"label": label, "secret": w})
    print(json.dumps({"changed": True, "config": config, "added": new_wallets}))
' "$config" "$detected" 2>/dev/null)
        local changed
        changed=$(echo "$sync_result" | jq -r '.changed' 2>/dev/null)
        if [ "$changed" = "true" ]; then
            echo "$sync_result" | jq -r '.config' > "$WALLET_CONFIG"
            config=$(cat "$WALLET_CONFIG")
            local added
            added=$(echo "$sync_result" | jq -r '.added | join(", ")' 2>/dev/null)
            echo -e "${GREEN}Auto-added new wallet(s): ${added}${NC}"
        fi
    fi

    # WebAuthn or 6-digit code gate
    _reveal_gate "$use_cli" || return 0
    local challenge="$_REVEAL_CHALLENGE"
    local user_code="$_REVEAL_CODE"

    echo -e "${CYAN}Fetching wallet data...${NC}"

    # Temp file for Python result (avoids multi-line JSON parsing issues)
    local wallet_result_file="${XDG_RUNTIME_DIR:-/tmp}/scrt4-wallet-$$.json"

    # Python does everything: confirm challenge, fetch balances, prices, format output
    python3 -c '
import json, sys, os, socket, urllib.request, urllib.parse, time, datetime

challenge = sys.argv[1]
user_code = sys.argv[2]
sock_path = sys.argv[3]
config = json.loads(sys.argv[4])
result_file = sys.argv[5]

def write_result(obj):
    with open(result_file, "w") as f:
        json.dump(obj, f)
    sys.exit(0)

def send_daemon(req):
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(10)
    s.connect(sock_path)
    s.sendall(json.dumps(req).encode() + b"\n")
    s.shutdown(socket.SHUT_WR)
    chunks = []
    while True:
        try:
            d = s.recv(65536)
            if not d: break
            chunks.append(d)
        except: break
    s.close()
    return json.loads(b"".join(chunks))

def rpc_call(url, method, params):
    data = json.dumps({"jsonrpc": "2.0", "method": method, "params": params, "id": 1}).encode()
    req = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"})
    try:
        resp = json.loads(urllib.request.urlopen(req, timeout=15).read())
        return resp.get("result")
    except Exception as e:
        return None

def etherscan_get(base_url, params, api_key):
    if not api_key:
        return []
    params["apikey"] = api_key
    url = base_url + "?" + urllib.parse.urlencode(params)
    try:
        resp = json.loads(urllib.request.urlopen(url, timeout=15).read())
        r = resp.get("result", [])
        return r if isinstance(r, list) else []
    except:
        return []

def coingecko_prices(ids):
    url = "https://api.coingecko.com/api/v3/simple/price?ids=" + ",".join(ids) + "&vs_currencies=usd"
    try:
        return json.loads(urllib.request.urlopen(url, timeout=10).read())
    except:
        return {}

def coingecko_token_price(platform, contract):
    url = f"https://api.coingecko.com/api/v3/simple/token_price/{platform}?contract_addresses={contract}&vs_currencies=usd"
    try:
        resp = json.loads(urllib.request.urlopen(url, timeout=8).read())
        return resp.get(contract.lower(), {}).get("usd", 0)
    except:
        return 0

# ── Uniswap V3 on-chain pricing ──
# Whitelisted tokens: contract -> (symbol, decimals, pool_address, is_token0)
# Pool addresses are Uniswap V3 pools paired with WETH or USDC
KNOWN_TOKENS = {
    # WETH — price equals ETH
    "0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2": ("WETH", 18, None, None),
    # wstETH/WETH 0.01% pool — token0=wstETH, token1=WETH
    "0x7f39c581f595b53c5cb19bd0b3f8da6c935e2ca0": ("wstETH", 18, "0x109830a1AAaD605BbF02a9dFA7B0B92EC2FB7dAa", True),
    # LINK/WETH 0.3% pool — token0=LINK, token1=WETH
    "0x514910771af9ca656af840dff83e8264ecf986ca": ("LINK", 18, "0xa6Cc3C2531FdaA6Ae1A3CA84c2855806728693e8", True),
    # USDC — stablecoin, always $1
    "0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48": ("USDC", 6, None, None),
    # USDT — stablecoin, always $1
    "0xdac17f958d2ee523a2206206994597c13d831ec7": ("USDT", 6, None, None),
    # DAI — stablecoin, always $1
    "0x6b175474e89094c44da98b954eedeac495271d0f": ("DAI", 18, None, None),
}
STABLECOINS = {"0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48", "0xdac17f958d2ee523a2206206994597c13d831ec7", "0x6b175474e89094c44da98b954eedeac495271d0f"}
WETH_CONTRACT = "0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2"

def uniswap_v3_price(rpc_url, pool_address, is_token0, token_decimals, pair_decimals=18):
    """Get token price in the paired asset via Uniswap V3 slot0().
       Returns price of the target token in units of the paired token."""
    # slot0() selector = 0x3850c7bd
    result = rpc_call(rpc_url, "eth_call", [{"to": pool_address, "data": "0x3850c7bd"}, "latest"])
    if not result or result == "0x":
        return 0
    try:
        sqrt_price_x96 = int(result[:66], 16)  # first 32 bytes
        # price = (sqrtPriceX96)^2 / 2^192
        price_raw = (sqrt_price_x96 ** 2) / (2 ** 192)
        # Adjust for decimal difference
        decimal_adj = 10 ** (token_decimals - pair_decimals)
        if is_token0:
            # price_raw = token1_per_token0, so target price = price_raw / decimal_adj
            return price_raw / decimal_adj
        else:
            # price_raw = token0_per_token1, invert
            if price_raw == 0:
                return 0
            return (1 / price_raw) * decimal_adj
    except:
        return 0

def get_token_usd_price(rpc_url, contract, eth_price, price_cache):
    """Get USD price for a token. Uses on-chain Uniswap V3 for whitelisted tokens."""
    c = contract.lower()
    if c in price_cache:
        return price_cache[c]

    price = 0
    if c in KNOWN_TOKENS:
        symbol, decimals, pool, is_token0 = KNOWN_TOKENS[c]
        if c == WETH_CONTRACT:
            price = eth_price
        elif c in STABLECOINS:
            price = 1.0
        elif pool:
            # Query Uniswap V3 pool for price in WETH, then multiply by ETH price
            price_in_weth = uniswap_v3_price(rpc_url, pool, is_token0, decimals, 18)
            price = price_in_weth * eth_price
    else:
        # Unknown token — try CoinGecko single lookup (may fail on rate limit)
        price = coingecko_token_price("ethereum", contract)

    price_cache[c] = price
    return price

def main():
    # ── Confirm challenge and get secrets ──
    resp = send_daemon({
        "method": "reveal_all_confirm",
        "params": {"challenge": challenge, "code": user_code}
    })

    if not resp.get("success"):
        write_result({"error": resp.get("error", "Unknown error")})

    secrets = resp.get("data", {}).get("secrets", {})

    rpc_url = secrets.get(config.get("rpc", ""), "")
    etherscan_key = secrets.get(config.get("etherscan", ""), "")
    wallets = config.get("wallets", [])

    if not rpc_url:
        for k in list(secrets.keys()): secrets[k] = "[CLEARED]"
        write_result({"error": "RPC secret is empty or missing. Run: scrt4 wallet setup"})

    # ── Fetch ETH price ──
    prices = coingecko_prices(["ethereum"])
    eth_price = prices.get("ethereum", {}).get("usd", 0)

    lines = []
    lines.append("=" * 63)
    lines.append("             LLM Secrets  -  Wallet Dashboard")
    lines.append("=" * 63)
    lines.append("")
    ts_now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    lines.append(f"  ETH Price: ${eth_price:,.2f}     ({ts_now})")
    lines.append("")

    total_usd = 0.0
    token_price_cache = {}
    seen_addresses = {}  # address -> label (dedup wallets with same address)

    for w in wallets:
        label = w.get("label", w["secret"])
        address = secrets.get(w["secret"], "").strip()

        if not address:
            lines.append(f"  -- {label} --")
            lines.append(f"    Secret \"{w['secret']}\" is empty")
            lines.append("")
            continue

        # Skip duplicate addresses (e.g. PUBLIC_KEY and MM_WALLET with same value)
        addr_lower = address.lower()
        if addr_lower in seen_addresses:
            lines.append(f"  -- {label} -- (same as {seen_addresses[addr_lower]}, skipped)")
            lines.append("")
            continue
        seen_addresses[addr_lower] = label

        is_evm = address.startswith("0x") and len(address) == 42

        short = f"{address[:6]}...{address[-4:]}" if len(address) > 12 else address
        lines.append(f"  -- {label} ({short}) --")
        lines.append(f"    Address: {address}")

        if not is_evm:
            lines.append(f"    Non-EVM address (Solana/other) - balance check not yet supported")
            lines.append("")
            continue

        # ETH balance
        eth_bal = 0.0
        bal_result = rpc_call(rpc_url, "eth_getBalance", [address, "latest"])
        if bal_result:
            try:
                eth_bal = int(bal_result, 16) / 1e18
            except: pass
        eth_usd = eth_bal * eth_price
        total_usd += eth_usd
        lines.append(f"    ETH     {eth_bal:>14.6f}    ${eth_usd:>12,.2f}")

        # ERC-20 tokens via Alchemy + Etherscan fallback
        token_result = rpc_call(rpc_url, "alchemy_getTokenBalances", [address, "erc20"])
        token_lines = []
        seen_contracts = set()

        if token_result and "tokenBalances" in token_result:
            non_zero = []
            for t in token_result["tokenBalances"]:
                try:
                    raw = int(t["tokenBalance"], 16)
                    if raw > 0:
                        non_zero.append((t["contractAddress"], raw))
                except:
                    pass

            for contract, raw_balance in non_zero[:50]:
                meta = rpc_call(rpc_url, "alchemy_getTokenMetadata", [contract])
                if not meta:
                    continue
                symbol = meta.get("symbol", "???")
                decimals = meta.get("decimals", 18) or 18
                balance = raw_balance / (10 ** decimals)
                seen_contracts.add(contract.lower())

                if balance < 0.0001:
                    continue

                # Price lookup (on-chain for whitelisted, CoinGecko fallback)
                token_usd_price = get_token_usd_price(rpc_url, contract, eth_price, token_price_cache)

                token_usd = balance * token_usd_price
                total_usd += token_usd

                if token_usd > 0.01:
                    token_lines.append((token_usd, f"    {symbol:<8}{balance:>14,.4f}    ${token_usd:>12,.2f}"))
                else:
                    token_lines.append((0, f"    {symbol:<8}{balance:>14,.4f}"))

        # Etherscan ERC-20 token transfer history (catches tokens Alchemy may miss)
        if etherscan_key:
            etk = etherscan_get("https://api.etherscan.io/api", {
                "module": "account", "action": "tokentx",
                "address": address, "startblock": 0, "endblock": 99999999,
                "page": 1, "offset": 100, "sort": "desc"
            }, etherscan_key)
            extra_contracts = set()
            for tx in etk:
                ca = tx.get("contractAddress", "").lower()
                if ca and ca not in seen_contracts:
                    extra_contracts.add(ca)
            for ca in list(extra_contracts)[:20]:
                # Check on-chain balance for this token
                bal_hex = rpc_call(rpc_url, "eth_call", [
                    {"to": ca, "data": "0x70a08231" + address[2:].lower().zfill(64)}, "latest"
                ])
                if not bal_hex:
                    continue
                try:
                    raw_balance = int(bal_hex, 16)
                except:
                    continue
                if raw_balance == 0:
                    continue
                meta = rpc_call(rpc_url, "alchemy_getTokenMetadata", [ca])
                if not meta:
                    continue
                symbol = meta.get("symbol", "???")
                decimals = meta.get("decimals", 18) or 18
                balance = raw_balance / (10 ** decimals)
                if balance < 0.0001:
                    continue
                seen_contracts.add(ca)
                token_usd_price = get_token_usd_price(rpc_url, ca, eth_price, token_price_cache)
                token_usd = balance * token_usd_price
                total_usd += token_usd
                if token_usd > 0.01:
                    token_lines.append((token_usd, f"    {symbol:<8}{balance:>14,.4f}    ${token_usd:>12,.2f}"))
                else:
                    token_lines.append((0, f"    {symbol:<8}{balance:>14,.4f}"))

        # Sort tokens by USD value descending
        token_lines.sort(key=lambda x: -x[0])
        for _, tl in token_lines:
            lines.append(tl)

        # Recent transactions via Etherscan
        if etherscan_key:
            txs = etherscan_get("https://api.etherscan.io/api", {
                "module": "account", "action": "txlist",
                "address": address, "startblock": 0, "endblock": 99999999,
                "page": 1, "offset": 5, "sort": "desc"
            }, etherscan_key)

            if txs:
                lines.append("")
                lines.append("    Recent transactions:")
                for tx in txs[:5]:
                    try:
                        value_eth = int(tx.get("value", "0")) / 1e18
                        from_addr = tx.get("from", "")
                        to_addr = tx.get("to", "")
                        is_out = from_addr.lower() == address.lower()
                        direction = "SENT" if is_out else "RECV"
                        other = to_addr if is_out else from_addr
                        other_short = f"{other[:6]}...{other[-4:]}" if other else "contract"
                        ts = int(tx.get("timeStamp", "0"))
                        date = datetime.datetime.fromtimestamp(ts).strftime("%m/%d %H:%M")
                        status = "+" if tx.get("isError") == "0" else "x"
                        lines.append(f"      {status} {date}  {direction}  {value_eth:.4f} ETH  {other_short}")
                    except:
                        pass

        lines.append("")

    lines.append("  " + "=" * 59)
    lines.append(f"  TOTAL PORTFOLIO VALUE:  ${total_usd:>12,.2f}")
    lines.append("  " + "=" * 59)

    # Clear secrets
    for k in list(secrets.keys()):
        secrets[k] = "[CLEARED]"
    del secrets

    write_result({"success": True, "output": "\n".join(lines), "total_usd": total_usd})

try:
    main()
except Exception as e:
    import traceback
    write_result({"error": str(e) + "\n" + traceback.format_exc()})
' "$challenge" "$user_code" "$SOCKET" "$config" "$wallet_result_file" 2>/dev/null

    local py_rc=$?

    # Read result from temp file
    if [ ! -f "$wallet_result_file" ]; then
        echo -e "${RED}Wallet fetch failed (Python produced no result).${NC}" >&2
        if [ $py_rc -ne 0 ]; then
            echo -e "${YELLOW}Python exited with code ${py_rc}. Check that 'cryptography' package is installed.${NC}" >&2
        fi
        return 1
    fi

    local py_json
    py_json=$(cat "$wallet_result_file")
    rm -f "$wallet_result_file"

    local py_err=$(echo "$py_json" | jq -r '.error // empty')
    if [ -n "$py_err" ]; then
        echo -e "${RED}${py_err}${NC}" >&2
        return 1
    fi

    local output
    output=$(echo "$py_json" | jq -r '.output')

    # Display
    if [ "$use_cli" = true ] || ! command -v zenity &>/dev/null; then
        echo ""
        echo "$output"
        echo ""
    else
        zenity --text-info \
            --title="LLM Secrets — Wallet Dashboard" \
            --width=700 --height=600 \
            --font="monospace 11" \
            --ok-label="  Close  " \
            <<< "$output" 2>/dev/null || true
    fi
}

cmd_wallet() {
    case "${1:-}" in
        setup)  shift; _wallet_setup "$@" ;;
        *)      _wallet_display "$@" ;;
    esac
}

# ── Zenity Menu ──────────────────────────────────────────────────────

cmd_menu() {
    if ! _has_gui; then
        if command -v zenity >/dev/null 2>&1; then
            echo -e "${YELLOW}No display available (DISPLAY/WAYLAND_DISPLAY unset).${NC}" >&2
            echo -e "${YELLOW}Falling back to text help.${NC}" >&2
        else
            echo -e "${YELLOW}zenity not installed. Falling back to text help.${NC}" >&2
        fi
        cmd_help
        return
    fi

  while true; do
    # Get live status
    local status_line="Inactive"
    local status_color="#f59e0b"
    local response
    response=$(send_request '{"method":"status"}' 2>/dev/null)
    local active=$(echo "$response" | jq -r '.data.active // false' 2>/dev/null)
    if [ "$active" = "true" ]; then
        local remaining=$(echo "$response" | jq -r '.data.remaining // 0' 2>/dev/null)
        local hours=$((remaining / 3600))
        local mins=$(( (remaining % 3600) / 60 ))
        status_line="Active  ·  ${hours}h ${mins}m remaining"
        status_color="#22c55e"
    fi

    local secret_count="?"
    local list_response
    list_response=$(send_request '{"method":"list"}' 2>/dev/null)
    local list_ok=$(echo "$list_response" | jq -r '.success // false' 2>/dev/null)
    if [ "$list_ok" = "true" ]; then
        secret_count=$(echo "$list_response" | jq -r '.data.names | length' 2>/dev/null)
    fi

    local choice
    choice=$(zenity --list \
        --title="LLM Secrets" \
        --text="<span font='22' weight='bold'>LLM Secrets</span>   <span font='11' color='#94a3b8'>v${VERSION} (WebAuthn)</span>\n\n<span font='11' weight='bold' color='${status_color}'>●</span>  <span font='12' color='#64748b'>${status_line}</span>  <span font='12' color='#cbd5e1'>·</span>  <span font='12' color='#64748b'>${secret_count} secrets</span>\n<span font='10' color='#94a3b8'>Start typing to search</span>\n" \
        --column="Command" --column="Description" \
        --print-column=1 \
        "unlock" "Authenticate via browser (localhost)" \
        "status" "Check session status" \
        "list" "List secret names" \
        "view" "View secret values (GUI)" \
        "add" "Add secrets (GUI notepad)" \
        "import" "Import from .env file (file picker)" \
        "share" "Send secrets via Magic Wormhole" \
        "receive" "Receive secrets via Magic Wormhole" \
        "wallet" "Wallet dashboard (balances, tokens, activity)" \
        "wallet setup" "Configure wallet dashboard" \
        "run ..." "Run command with secrets" \
        "encrypt-folder" "Encrypt a folder into .scrt4 archive" \
        "decrypt-folder" "Decrypt a .scrt4 archive" \
        "backup-vault" "Backup vault to Google Drive" \
        "backup-vault --local" "Backup vault locally" \
        "extend" "Reset session timer" \
        "backup-key" "Show master key (disaster recovery)" \
        "backup-key --save" "Save encrypted master key backup" \
        "recover" "Recover master key from backup file" \
        "backup-guide" "Backup & recovery guide (notepad)" \
        "setup" "Register new WebAuthn credential" \
        "wa-state" "Check WebAuthn 2FA state" \
        "wa-off" "Turn off 2FA for view" \
        "wa-on" "Turn on 2FA for view" \
        "wa-off --unlock" "Turn off 2FA for unlock" \
        "wa-on --unlock" "Turn on 2FA for unlock" \
        "logout" "Clear session" \
        --ok-label="  Run  " \
        --cancel-label="  ✕  Close  " \
        --width=480 --height=560 2>/dev/null) || break

    [ -z "$choice" ] && break

    case "$choice" in
        "run ...")
            local cmd
            cmd=$(zenity --entry \
                --title="LLM Secrets — Run" \
                --text="<span font='14' weight='bold'>Run command with secrets</span>\n\n<span font='11' color='#64748b'>Use \$env[NAME] for secret injection</span>\n" \
                --entry-text='echo "$env[SECRET_NAME]"' \
                --ok-label="  Execute  " \
                --width=500 2>/dev/null) || continue
            [ -z "$cmd" ] && continue
            echo -e "${CYAN}Running: ${cmd}${NC}"
            cmd_run "$cmd"
            ;;
        "backup-vault --local")
            local dest
            dest=$(zenity --file-selection \
                --title="Choose backup destination" \
                --directory 2>/dev/null) || continue
            [ -z "$dest" ] && continue
            cmd_backup_vault --local "$dest"
            ;;
        "backup-key --save")
            local save_dest
            save_dest=$(zenity --file-selection \
                --title="LLM Secrets — Choose Backup Destination" \
                --directory 2>/dev/null) || continue
            [ -z "$save_dest" ] && continue

            # WebAuthn step-up: handle_backup_key rejects requests without
            # a fresh verification, even inside an active session.
            _wa_gate || continue

            # Retrieve master key
            echo -e "${CYAN}Retrieving master key from daemon...${NC}"
            local bk_response
            bk_response=$(send_request '{"method":"backup_key"}')
            local bk_success=$(echo "$bk_response" | jq -r '.success // false')
            if [ "$bk_success" != "true" ]; then
                local bk_error=$(echo "$bk_response" | jq -r '.error // "Unknown error"')
                zenity --error --title="LLM Secrets" \
                    --text="Failed to retrieve master key:\n${bk_error}" \
                    --width=400 2>/dev/null
                continue
            fi
            local bk_key=$(echo "$bk_response" | jq -r '.data.key')

            # Get password via GUI
            local pw_result
            pw_result=$(zenity --forms \
                --title="LLM Secrets — Encrypt Master Key" \
                --text="<span font='14' weight='bold'>Choose a recovery password</span>\n\n<span font='11' color='#64748b'>You will need this password to recover your master key later.\nMinimum 8 characters. Store it separately from the backup file.</span>\n" \
                --add-password="Recovery password" \
                --add-password="Confirm password" \
                --ok-label="  Encrypt & Save  " \
                --cancel-label="  Cancel  " \
                --width=460 2>/dev/null) || continue
            [ -z "$pw_result" ] && continue

            local pw1 pw2
            pw1=$(echo "$pw_result" | cut -d'|' -f1)
            pw2=$(echo "$pw_result" | cut -d'|' -f2)

            if [ "$pw1" != "$pw2" ]; then
                zenity --error --title="LLM Secrets" \
                    --text="Passwords do not match. No file was created." \
                    --width=350 2>/dev/null
                continue
            fi
            if [ ${#pw1} -lt 8 ]; then
                zenity --error --title="LLM Secrets" \
                    --text="Password must be at least 8 characters." \
                    --width=350 2>/dev/null
                continue
            fi

            # Encrypt
            local bk_out_file="${save_dest}/encrypted-master-key-instructions.json"
            local bk_encrypt_script=$(mktemp)
            cat > "$bk_encrypt_script" << 'BKPYEOF'
import json, os, sys, hashlib, base64, subprocess, datetime
lines = sys.stdin.read().split('\n', 1)
master_key, password = lines[0], lines[1]
out_file = sys.argv[1]
salt = os.urandom(16)
iv = os.urandom(16)
derived_key = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000, dklen=32)
proc = subprocess.run(['openssl', 'enc', '-aes-256-cbc',
    '-K', derived_key.hex(), '-iv', iv.hex(), '-nosalt'],
    input=master_key.encode(), capture_output=True)
if proc.returncode != 0:
    print('Encryption failed', file=sys.stderr); sys.exit(1)
backup = {
    'Type': 'MasterKeyBackup', 'Version': '2.0',
    'CreatedAt': datetime.datetime.now().astimezone().isoformat(),
    'SecurityMode': 'webauthn-prf',
    'Salt': base64.b64encode(salt).decode(),
    'IV': base64.b64encode(iv).decode(),
    'EncryptedMasterKey': base64.b64encode(proc.stdout).decode(),
    'DecryptionInstructions': {
        'Algorithm': 'AES-256-CBC', 'KeyDerivation': 'PBKDF2-SHA256',
        'Iterations': 100000, 'KeyLength': 32,
        'HowToDecrypt': [
            '1. Run: scrt4 recover encrypted-master-key-instructions.json',
            '2. Enter your recovery password when prompted',
            '3. Your master key will be displayed',
        ],
        'InlineRecoveryScript': (
            '#!/usr/bin/env python3\n'
            'import json, sys, hashlib, base64, subprocess, getpass\n'
            'with open(sys.argv[1], encoding="utf-8-sig") as f: backup = json.load(f)\n'
            'pw = getpass.getpass("Recovery password: ")\n'
            'salt = base64.b64decode(backup["Salt"])\n'
            'iv = base64.b64decode(backup["IV"])\n'
            'enc = base64.b64decode(backup["EncryptedMasterKey"])\n'
            'iters = backup.get("DecryptionInstructions", {}).get("Iterations", 100000)\n'
            'dk = hashlib.pbkdf2_hmac("sha256", pw.encode(), salt, iters, dklen=32)\n'
            'r = subprocess.run(["openssl", "enc", "-aes-256-cbc", "-d",\n'
            '    "-K", dk.hex(), "-iv", iv.hex(), "-nosalt"],\n'
            '    input=enc, capture_output=True)\n'
            'if r.returncode != 0: print("Failed.", file=sys.stderr); sys.exit(1)\n'
            'key = r.stdout.decode().rstrip(chr(0))\n'
            'print(f"Master Key: {key} ({len(key)} chars)")\n')
    }
}
with open(out_file, 'w') as f:
    json.dump(backup, f, indent=2)
print('OK')
BKPYEOF
            local bk_result
            bk_result=$(printf '%s\n%s' "$bk_key" "$pw1" | python3 "$bk_encrypt_script" "$bk_out_file")
            local bk_rc=$?
            rm -f "$bk_encrypt_script"

            if [ $bk_rc -ne 0 ] || [ "$bk_result" != "OK" ]; then
                zenity --error --title="LLM Secrets" \
                    --text="Encryption failed." --width=300 2>/dev/null
                continue
            fi

            zenity --info --title="LLM Secrets" \
                --text="<span font='14' weight='bold'>Encrypted master key saved!</span>\n\n<span font='11'><b>Backup:</b>  ${bk_out_file}\n<b>Encrypted:</b>  Yes (AES-256-CBC, password-protected)\n<b>Raw key:</b>  NOT stored in these files</span>\n\n<span font='11' color='#f59e0b'>Remember your recovery password — it cannot be reset!</span>" \
                --ok-label="  Done  " \
                --width=520 2>/dev/null
            ;;
        "recover")
            _recover_wizard
            ;;
        *)
            echo -e "${CYAN}scrt4 ${choice}${NC}"
            case "$choice" in
                unlock)     cmd_unlock ;;
                status)
                    local status_out
                    status_out=$(cmd_status 2>&1)
                    zenity --info --title="LLM Secrets — Status" \
                        --text="$status_out" --width=400 2>/dev/null || true
                    ;;
                list)
                    local list_out
                    list_out=$(cmd_list 2>&1)
                    if [ -z "$list_out" ]; then
                        zenity --info --title="LLM Secrets — Secret Names" \
                            --text="No secrets stored.\n\nAdd with: scrt4 add KEY=value" \
                            --width=350 2>/dev/null
                    else
                        zenity --text-info --title="LLM Secrets — Secret Names" \
                            --width=500 --height=400 --font="monospace" \
                            <<< "$list_out" 2>/dev/null || true
                    fi
                    ;;
                view)           cmd_view ;;
                add)            cmd_add ;;
                import)         cmd_import ;;
                share)          cmd_share ;;
                receive)
                    local recv_code=""
                    if command -v zenity &>/dev/null; then
                        recv_code=$(zenity --entry \
                            --title="LLM Secrets — Receive" \
                            --text="<span font='14' weight='bold'>Enter the wormhole code</span>\n\n<span font='11' color='#64748b'>The sender will show you a code like: 7-crossover-headline</span>\n" \
                            --ok-label="  Receive →  " \
                            --cancel-label="  Cancel  " \
                            --width=450 2>/dev/null) || continue
                    fi
                    if [ -n "$recv_code" ]; then
                        cmd_share --receive --code "$recv_code"
                    else
                        cmd_share --receive
                    fi
                    ;;
                wallet)         cmd_wallet ;;
                "wallet setup") cmd_wallet setup ;;
                encrypt-folder)
                    local ef_folder
                    ef_folder=$(zenity --file-selection --directory --title="Select Folder to Encrypt" \
                        2>/dev/null) || continue
                    [ -n "$ef_folder" ] && cmd_encrypt_folder "$ef_folder"
                    ;;
                decrypt-folder)
                    local df_file
                    df_file=$(zenity --file-selection --title="Select .scrt4 Archive" \
                        --file-filter="Scrt4 archives|*.scrt4" \
                        2>/dev/null) || continue
                    [ -n "$df_file" ] && cmd_decrypt_folder "$df_file"
                    ;;
                backup-vault)   cmd_backup_vault ;;
                extend)         cmd_extend ;;
                backup-key)     cmd_backup_key ;;
                backup-guide)   cmd_backup_guide ;;
                setup)          cmd_setup ;;
                wa-state)       cmd_wa_state ;;
                wa-off)         cmd_wa_off ;;
                wa-on)          cmd_wa_on ;;
                "wa-off --unlock") cmd_wa_off --unlock ;;
                "wa-on --unlock")  cmd_wa_on --unlock ;;
                logout)         cmd_logout ;;
            esac
            ;;
    esac
  done
}

# ── Help ─────────────────────────────────────────────────────────────

cmd_help() {
    echo "scrt4 v${VERSION} - secure secret injector (WebAuthn PRF edition)"
    echo ""
    echo "USAGE:"
    echo "  scrt4 <command> [options]"
    echo ""
    echo "COMMANDS:"
    echo "  daemon              Start the scrt4 daemon (foreground)"
    echo "  setup [agent]       Register WebAuthn credential via QR code"
    echo "  setup agent         Non-interactive setup (QR in terminal, for AI agents)"
    echo "  unlock [ttl]        Authenticate via WebAuthn QR (default: 60000s / ~16.7h)"
    echo "  unlock --cli [ttl]  Authenticate in terminal only (for AI agents)"
    echo "  status              Check session status"
    echo "  list [--tags]       List secret names (--tags to show tags, --tag TAG to filter)"
    echo "  run <command>       Run command with \$env[NAME] substitution"
    echo "  add [KEY=val ...]   Add secrets (GUI notepad if no args, or KEY=value on CLI)"
    echo "  import [file]       Import secrets from .env file (GUI file picker if no args)"
    echo "  tag NAME t1 [t2..] Tag a secret with one or more labels"
    echo "  untag NAME t1      Remove a tag from a secret"
    echo "  tags                List all tags"
    echo "  share [KEY ...]     Share secrets via Magic Wormhole (GUI picker if no args)"
    echo "  share --all         Share all secrets"
    echo "  share --receive     Receive shared secrets (alias: receive)"
    echo "  receive [--code C]  Receive shared secrets"
    echo "  wallet              Wallet dashboard (balances, tokens, prices)"
    echo "  wallet setup        Configure wallet dashboard (pick wallets, RPC, explorer)"
    echo "  view [--cli]        View secrets (GUI default, --cli for terminal)"
    echo "  menu                Open GUI menu (falls back to text help on headless)"
    echo "  extend [ttl]        Reset session timer"
    echo "  logout              Clear session (aliases: lock, clear)"
    echo "  wa-state            Check WebAuthn 2FA state"
    echo "  wa-off [--unlock]   Turn off WebAuthn 2FA for view (or unlock)"
    echo "  wa-on [--unlock]    Turn on WebAuthn 2FA for view (or unlock)"
    echo "  encrypt-folder <path>         Encrypt a folder into .scrt4 archive"
    echo "  decrypt-folder <file.scrt4>   Decrypt a .scrt4 archive"
    echo "  backup-folder <path>          Alias for encrypt-folder"
    echo "  recover-folder <file.scrt4>   Decrypt .scrt4 (supports --key for offline recovery)"
    echo "  backup-vault [--local <dir>]  Backup encrypted vault"
    echo "  backup-key [--save <dir>]     Show or save master key"
    echo "  recover [file]      Recover master key from backup (GUI wizard if no args)"
    echo "  backup-guide        Open backup & recovery guide"
    echo "  help                Show this help"
    echo ""
    echo "FOLDER ENCRYPTION OPTIONS:"
    echo "  --max-size SIZE   Max folder size (default: 500M). e.g., 1G, 100M"
    echo "  --include-all     Include all file types (skip only excluded dirs/exts)"
    echo "  --output DIR      Output directory for archive or extracted files"
    echo "  --key KEY         (recover-folder) Base64 master key for offline recovery"
    echo ""
    echo "GETTING STARTED:"
    echo "  scrt4 daemon &                # Start daemon in background"
    echo "  scrt4 setup                   # Register WebAuthn credential via phone"
    echo "  scrt4 setup agent             # Same, but QR in terminal (for Claude Code)"
    echo "  scrt4 unlock                  # Authenticate (scan QR with phone)"
    echo "  scrt4 unlock --cli            # Same, but QR in terminal (for Claude Code)"
    echo ""
    echo "EXAMPLES:"
    echo "  scrt4 unlock 28800            # 8 hour session"
    echo "  scrt4 list                    # List secret names"
    echo "  scrt4 run 'curl -H \"Auth: Bearer \$env[API_KEY]\" https://api.example.com'"
    echo "  scrt4 add API_KEY=sk-123      # Add a secret"
    echo "  scrt4 import                  # Import .env file (file picker)"
    echo "  scrt4 import ~/project/.env   # Import from specific file"
    echo "  scrt4 tag API_KEY prod auth   # Tag a secret"
    echo "  scrt4 list --tag prod         # List secrets tagged 'prod'"
    echo "  scrt4 list --tags             # List all secrets with their tags"
    echo "  scrt4 view                    # View secrets in GUI"
    echo "  scrt4 encrypt-folder ~/secrets # Encrypt folder → ~/secrets.scrt4"
    echo "  scrt4 decrypt-folder ~/secrets.scrt4  # Decrypt → ~/secrets/"
    echo "  scrt4 recover-folder backup.scrt4 --key \$(cat key.txt)  # Offline recovery"
    echo "  scrt4 backup-key --save .     # Save encrypted master key backup"
    echo "  scrt4 recover file.json       # Recover master key from backup"
    echo "  scrt4 share                   # Pick secrets to share (GUI checklist)"
    echo "  scrt4 share API_KEY DB_PASS   # Share specific secrets"
    echo "  scrt4 share --all             # Share all secrets"
    echo "  scrt4 receive                 # Receive (prompts for code)"
    echo "  scrt4 receive --code 7-crossover-headline"
    echo "  scrt4 wallet                  # View wallet balances and portfolio"
    echo "  scrt4 wallet setup            # Configure wallet tracking"
    echo "  scrt4 wallet --cli            # Wallet dashboard in terminal"
}

# ── Main Dispatch ────────────────────────────────────────────────────

# "daemon" subcommand starts the daemon directly
if [ "${1:-}" = "daemon" ]; then
    exec scrt4-daemon
fi

# Daemon health check — returns 0 if the socket exists AND a client can
# connect to it. Catches the case where the socket file survives (e.g.
# inside a Docker container across `docker stop`/`start`, or after a
# daemon crash) but no daemon is actually listening on the other end.
_daemon_alive() {
    [ -S "$SOCKET" ] || return 1
    if command -v socat &>/dev/null; then
        timeout 1 socat -u /dev/null UNIX-CONNECT:"$SOCKET" >/dev/null 2>&1
    else
        timeout 1 python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(1)
try:
    s.connect('$SOCKET')
    s.close()
except Exception:
    sys.exit(1)
" >/dev/null 2>&1
    fi
}

# All other commands require the daemon to be running — auto-start if needed
if ! _daemon_alive; then
    # Remove stale socket file (if any) so the daemon can bind a fresh one.
    rm -f "$SOCKET" 2>/dev/null || true
    echo -e "${CYAN}Starting daemon...${NC}" >&2
    nohup scrt4-daemon >/dev/null 2>&1 &
    disown
    # Wait for socket to appear (up to 3 seconds)
    for _i in $(seq 1 30); do
        [ -S "$SOCKET" ] && break
        sleep 0.1
    done
    if [ ! -S "$SOCKET" ]; then
        echo -e "${RED}Failed to start daemon (socket not found after 3s)${NC}" >&2
        exit 1
    fi
fi

# No args → GUI menu (backgrounded so terminal stays usable)
if [ $# -eq 0 ]; then
    cmd_menu &
    disown
    exit 0
fi

# Route command
case "$1" in
    unlock)             shift; cmd_unlock "$@" ;;
    setup)              shift; cmd_setup "$@" ;;
    status)             cmd_status ;;
    list)               shift; cmd_list "$@" ;;
    run)                shift; cmd_run "$@" ;;
    logout|lock|clear)  cmd_logout ;;
    extend)             shift; cmd_extend "$@" ;;
    view)               shift; _bg_if_gui cmd_view "$@" ;;
    add)                shift; _bg_if_gui cmd_add "$@" ;;
    import|env)         shift; _bg_if_gui cmd_import "$@" ;;
    share)              shift; _bg_if_gui cmd_share "$@" ;;
    receive)            shift; _bg_if_gui cmd_share --receive "$@" ;;
    wallet)             shift; _bg_if_gui cmd_wallet "$@" ;;
    tag)                shift; cmd_tag "$@" ;;
    untag)              shift; cmd_untag "$@" ;;
    tags)               cmd_tags ;;
    wa-state)           cmd_wa_state ;;
    wa-off)             shift; _bg_if_gui cmd_wa_off "$@" ;;
    wa-on)              shift; cmd_wa_on "$@" ;;
    encrypt-folder|backup-folder) shift; cmd_encrypt_folder "$@" ;;
    decrypt-folder)     shift; cmd_decrypt_folder "$@" ;;
    recover-folder)     shift; cmd_recover_folder "$@" ;;
    backup-vault)       shift; cmd_backup_vault "$@" ;;
    backup-key)         shift; _bg_if_gui cmd_backup_key "$@" ;;
    recover)            shift; _bg_if_gui cmd_recover "$@" ;;
    backup-guide)       _bg_if_gui cmd_backup_guide ;;
    menu)               _bg_if_gui cmd_menu ;;
    help|--help|-h)     cmd_help ;;
    -v|--version)       echo "scrt4 v${VERSION}" ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}" >&2
        cmd_help
        exit 1
        ;;
esac
